{% extends 'layouts/page.html.twig' %}

{% block title %}{{ article.title }} — La Boîte à Chimère{% endblock %}

{% block description %}{{ article.title }} — Retrouvez toutes les actualités et comptes-rendus de La Boîte à Chimère.{% endblock %}

{% block page_title %}{{ article.title }}{% endblock %}
{% block page_subtitle %}
	<p class="text-lg text-text-secondary max-w-2xl mx-auto">
		Publié dans la section Dernières Chimères
	</p>
{% endblock %}

{% block content %}
<article class="max-w-3xl mx-auto rounded-2xl border border-custom glass-card p-6 lg:p-10 shadow-xl relative overflow-hidden">
    <div class="flex items-center gap-3 mb-6">
        <span class="inline-block rounded-md bg-custom-orange/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-custom-orange">{{ article.tag }}</span>
    </div>

    {% if article.image %}
        <div class="mb-8 overflow-hidden rounded-xl border border-custom aspect-video relative shadow-lg shadow-black/20">
            <img src="{{ asset('images/articles/' ~ article.image) }}" alt="Illustration pour : {{ article.title }}" class="h-full w-full object-cover">
        </div>
    {% endif %}

    <div class="prose prose-invert max-w-none text-text-secondary text-sm lg:text-base leading-relaxed space-y-6">
        {{ article.content|raw }}
    </div>

    <div class="mt-8 pt-6 border-t border-custom flex justify-between">
        <a href="{{ path('app_home') }}" class="text-xs text-text-secondary hover:text-custom-orange transition-colors">&larr; Retour à l'accueil</a>
    </div>
</article>
{% endblock %}
