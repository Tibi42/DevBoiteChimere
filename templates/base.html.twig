<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        <script>
            // Thème : appliquer immédiatement + définir le toggle (inline = fonctionne toujours)
            (function(){
                var h=document.documentElement;
                var s=localStorage.getItem('theme');
                if(s==='light'||(!s&&window.matchMedia('(prefers-color-scheme: light)').matches)){
                    h.classList.add('light-mode');
                }
                function sync(){
                    var isLight=h.classList.contains('light-mode');
                    document.querySelectorAll('.theme-toggle-btn').forEach(function(btn){
                        var sun=btn.querySelector('.sun-icon');
                        var moon=btn.querySelector('.moon-icon');
                        if(sun)sun.classList.toggle('hidden',isLight);
                        if(moon)moon.classList.toggle('hidden',!isLight);
                    });
                }
                window.__toggleTheme=function(){
                    h.classList.toggle('light-mode');
                    localStorage.setItem('theme',h.classList.contains('light-mode')?'light':'dark');
                    sync();
                };
                document.addEventListener('DOMContentLoaded',sync);
                document.addEventListener('turbo:load',sync);
                document.addEventListener('turbo:render',sync);
            })();
        </script>
    </head>
    <body class="bg-custom-primary text-white">
        {% for label, messages in app.flashes(['success', 'warning', 'error']) %}
            {% for message in messages %}
                <div class="mx-auto max-w-[1240px] px-4 py-3 mt-4 rounded-xl border border-custom {{ label == 'success' ? 'bg-emerald-900/50 text-emerald-200' : (label == 'warning' ? 'bg-amber-900/50 text-amber-200' : 'bg-red-900/50 text-red-200') }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}

        {# ── Modale inscription activité (disponible sur toutes les pages) ── #}
        <div id="activity-modal" class="hidden fixed inset-0 z-[9999] bg-black/70 flex items-start justify-center p-4 overflow-y-auto">
            <div class="glass-card rounded-2xl border border-custom shadow-2xl w-full lg:max-w-lg relative p-6">
                <turbo-frame id="activity-modal-frame" loading="lazy"></turbo-frame>
            </div>
        </div>

        {# ── Bandeau cookies (caché par défaut, affiché par cookie_consent.js) ── #}
        <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[9999] bg-custom-tertiary border-t border-custom p-4 shadow-2xl hidden">
            <div class="mx-auto max-w-[1240px] flex flex-col sm:flex-row items-start sm:items-center gap-4">
                <p class="text-sm text-text-secondary flex-1">
                    Ce site utilise des cookies essentiels au fonctionnement (session, sécurité CSRF). Aucun cookie publicitaire n'est utilisé.
                </p>
                <div class="flex gap-2 shrink-0">
                    <button id="cookie-accept" class="rounded-lg bg-custom-orange px-4 py-2 text-xs font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all">
                        Accepter
                    </button>
                    <button id="cookie-refuse" class="rounded-lg border border-custom px-4 py-2 text-xs font-extrabold uppercase tracking-widest text-text-secondary hover:text-text-primary transition-all">
                        Refuser
                    </button>
                </div>
            </div>
        </div>
    </body>
</html>
