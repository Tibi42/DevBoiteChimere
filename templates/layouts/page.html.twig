		{% block content %}{% endblock %}
	</main>

	{# ── Footer ──────────────────────────────────────────────── #}
	<footer class="border-t border-custom bg-custom-tertiary py-16 relative z-10">
		<div class="mx-auto grid max-w-[1240px] gap-12 px-6 md:grid-cols-4">
			<div class="md:col-span-1">
