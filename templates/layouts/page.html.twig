					<a href="{{ path('app_home') }}" class="flex items-center gap-4 transition-all hover:opacity-80 z-[75]">
						<div class="h-10 w-10 shrink-0">
							<svg class="h-full w-full" viewbox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
								<path d="M20 2L36 12v16L20 38L4 28V12L20 2z" stroke="url(#logo)" stroke-width="1.5" fill="none"/>
								<path d="M20 8l10 6v8l-10 6-10-6v-8l10-6z" stroke="url(#logo2)" stroke-width="1" fill="none"/>
								<defs>
									<linearGradient id="logo" x1="4" y1="2" x2="36" y2="38" gradientunits="userSpaceOnUse">
										<stop stop-color="#14b8a6"/><stop offset="1" stop-color="#f8742c"/>
									</linearGradient>
									<linearGradient id="logo2" x1="10" y1="8" x2="30" y2="32" gradientunits="userSpaceOnUse">
										<stop stop-color="#14b8a6"/><stop offset="1" stop-color="#f8742c"/>
									</linearGradient>
								</defs>
							</svg>
						</div>
						<div class="flex flex-col leading-[0.9]">
							<span class="text-base font-extrabold uppercase tracking-tight text-text-primary leading-none">LA BOÎTE</span>
							<span class="text-base font-extrabold uppercase tracking-tight text-text-primary leading-none">À CHIMÈRE</span>
						</div>
					</a>
					{% if app.user %}
						<span class="hidden lg:block text-[11px] font-bold uppercase tracking-[0.1em] text-text-secondary">Bienvenue <span class="text-custom-orange">{{ app.user.username }}</span></span>
					{% endif %}

					<nav class="hidden lg:flex items-center gap-10">
						<a href="{{ path('app_home') }}" class="text-[11px] font-bold uppercase tracking-[0.1em] text-text-secondary hover:text-text-primary transition-colors">ACCUEIL</a>
						<a href="{{ path('app_jds') }}" class="text-[11px] font-bold uppercase tracking-[0.1em] {{ app.request.attributes.get('_route') == 'app_jds' ? 'text-custom-orange' : 'text-text-secondary hover:text-text-primary' }} transition-colors">JDS</a>
						<a href="{{ path('app_jdr') }}" class="text-[11px] font-bold uppercase tracking-[0.1em] {{ app.request.attributes.get('_route') == 'app_jdr' ? 'text-custom-orange' : 'text-text-secondary hover:text-text-primary' }} transition-colors">JDR</a>
						<a href="{{ path('app_gn') }}" class="text-[11px] font-bold uppercase tracking-[0.1em] {{ app.request.attributes.get('_route') == 'app_gn' ? 'text-custom-orange' : 'text-text-secondary hover:text-text-primary' }} transition-colors">GN</a>
						<a href="{{ path('app_association') }}" class="text-[11px] font-bold uppercase tracking-[0.1em] {{ app.request.attributes.get('_route') == 'app_association' ? 'text-custom-orange' : 'text-text-secondary hover:text-text-primary' }} transition-colors">ASSOCIATION</a>
						<a href="https://laboiteachimere.com/forum/" target="_blank" rel="noopener noreferrer" class="text-[11px] font-bold uppercase tracking-[0.1em] text-text-secondary hover:text-text-primary transition-colors">FORUM</a>
						{% if app.user %}
							<a href="{{ path('app_user_dashboard') }}" data-turbo="false" class="text-[11px] font-bold uppercase tracking-[0.1em] text-text-secondary hover:text-text-primary transition-colors">MON ESPACE</a>
						{% endif %}
						{% if is_granted('ROLE_ADMIN') %}
							<a href="{{ path('admin') }}" class="text-[11px] font-bold uppercase tracking-[0.1em] text-custom-orange hover:text-orange-400 transition-colors">DASHBOARD</a>
						{% endif %}
					</nav>

					<div class="flex items-center gap-4">
						<button type="button" onclick="window.__toggleTheme()" class="theme-toggle-btn p-2.5 rounded-lg bg-custom-tertiary border border-custom text-text-secondary hover:text-text-primary transition-all z-[75]" aria-label="Changer de thème">
							<svg class="h-5 w-5 sun-icon" fill="none" stroke="currentColor" viewbox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
							</svg>
							<svg class="h-5 w-5 moon-icon hidden" fill="none" stroke="currentColor" viewbox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
							</svg>
						</button>
						{% if app.user %}
							<a href="{{ path('app_logout') }}" class="hidden lg:block rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-gray-900 transition-all hover:bg-orange-600 hover:scale-105 shadow-lg shadow-custom-orange/20">
								DÉCONNEXION
							</a>
						{% else %}
							<button type="button" id="join-btn" class="hidden lg:block rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-gray-900 transition-all hover:bg-orange-600 hover:scale-105 shadow-lg shadow-custom-orange/20">
