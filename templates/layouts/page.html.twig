{% extends 'base.html.twig' %}

{% block importmap %}{{ importmap(['app', 'carousel.js']) }}{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
	function initTogglePassword() {
		document.querySelectorAll('[data-toggle-password]').forEach(function (btn) {
			if (btn._togglePasswordInit) return;
			btn._togglePasswordInit = true;
			btn.addEventListener('click', function () {
				var input = document.getElementById(btn.dataset.togglePassword);
				if (!input) return;
				var isHidden = input.type === 'password';
				input.type = isHidden ? 'text' : 'password';
				btn.querySelectorAll('.eye-closed').forEach(function (el) { el.classList.toggle('hidden', isHidden); });
				btn.querySelectorAll('.eye-open').forEach(function (el) { el.classList.toggle('hidden', !isHidden); });
			});
		});
	}
	document.addEventListener('DOMContentLoaded', initTogglePassword);
	document.addEventListener('turbo:load', initTogglePassword);
	</script>
{% endblock %}

{% block body %}
	{% set slides = carousel_slides() %}
	{# ── Hero banner ─────────────────────────────────────────── #}
	<section class="relative w-full min-h-[320px] lg:min-h-[400px] overflow-hidden">
		<img src="{{ asset('images/hero/' ~ (block('hero_image') is defined ? block('hero_image') : 'hero.jpg')) }}" alt="" fetchpriority="high" class="absolute inset-0 h-full w-full object-cover">
		<div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/80"></div>

		<div class="relative z-10">
			{# ── Carousel ────────────────────────────────────────── #}
			<section class="mx-auto max-w-[1240px] px-4 sm:px-8 lg:px-10 pt-6 lg:pt-10 mb-8 lg:mb-12" id="carousel-container" aria-label="Événements à la une">
				<div class="relative rounded-2xl border border-custom glass-card shadow-xl overflow-hidden">
					<div class="overflow-hidden rounded-2xl">
						<div id="carousel" class="flex h-auto" style="transform: translateX(0%); touch-action: pan-y;">
							{% for slide in slides %}
								{% set btnUrl = slide.btn_url|default('') %}
								{% if btnUrl %}
									<a href="{{ btnUrl }}" class="carousel-events-slide relative group cursor-pointer flex flex-shrink-0 flex-col sm:flex-row sm:items-center justify-between gap-2 sm:gap-4 p-3 sm:p-5 lg:px-6 lg:py-4 w-full min-w-full overflow-hidden hover:bg-white/5 transition-colors">
										<div class="flex-1">
											<span class="text-[9px] sm:text-[10px] font-bold uppercase tracking-[0.2em] {{ slide.tag_color }}">{{ slide.tag }}</span>
											<p class="text-sm sm:text-base lg:text-lg font-bold text-text-primary mt-0.5 leading-tight">{{ slide.title }}</p>
											<p class="text-xs sm:text-sm text-text-secondary mt-1">{{ slide.date }}</p>
										</div>
										<span class="w-full sm:w-auto text-center shrink-0 rounded-lg {{ slide.btn_class }} px-4 py-2 sm:px-5 sm:py-2.5 text-[9px] sm:text-[10px] lg:text-xs font-bold uppercase tracking-wider text-text-primary transition-all group-hover:scale-105 shadow-lg">
											{{ slide.btn_text }}
											<span class="absolute inset-0"></span>
										</span>
									</a>
								{% else %}
									<div class="carousel-events-slide relative group cursor-pointer flex flex-shrink-0 flex-col sm:flex-row sm:items-center justify-between gap-2 sm:gap-4 p-3 sm:p-5 lg:px-6 lg:py-4 w-full min-w-full overflow-hidden hover:bg-white/5 transition-colors">
										<div class="flex-1">
											<span class="text-[9px] sm:text-[10px] font-bold uppercase tracking-[0.2em] {{ slide.tag_color }}">{{ slide.tag }}</span>
											<p class="text-sm sm:text-base lg:text-lg font-bold text-text-primary mt-0.5 leading-tight">{{ slide.title }}</p>
											<p class="text-xs sm:text-sm text-text-secondary mt-1">{{ slide.date }}</p>
										</div>
										<span class="w-full sm:w-auto text-center shrink-0 rounded-lg {{ slide.btn_class }} px-4 py-2 sm:px-5 sm:py-2.5 text-[9px] sm:text-[10px] lg:text-xs font-bold uppercase tracking-wider text-text-primary transition-all group-hover:scale-105 shadow-lg">
											{{ slide.btn_text }}
											<span class="absolute inset-0"></span>
										</span>
									</div>
								{% endif %}
							{% endfor %}
						</div>
					</div>
				</div>
				<div id="carousel-events-dots" class="flex justify-center items-center gap-3 py-4 mt-2">
					{% for slide in slides %}
						<button type="button" class="carousel-events-dot h-3 w-3 rounded-full transition-all bg-white/50 hover:bg-white/80" data-index="{{ loop.index0 }}" data-slide="{{ loop.index0 }}" aria-label="Aller au slide {{ loop.index }}"></button>
					{% endfor %}
				</div>
			</section>

			{# ── Header / Navbar ────────────────────────────────── #}
			<header class="mx-auto max-w-[1240px] lg:max-w-[1360px] px-8 lg:px-10 mb-8 lg:mb-12">
				{{ include('partials/_navbar.html.twig') }}
			</header>

			{# ── Hero content (titre de la page) ────────────────── #}
			<div class="mx-auto max-w-[1240px] px-8 lg:px-10 pb-16 lg:pb-24 text-center">
				<h1 class="text-4xl lg:text-5xl font-bold uppercase tracking-[0.15em] text-text-primary mb-4">{% block page_title %}{% endblock %}</h1>
				{% block page_subtitle %}<p class="text-lg text-text-secondary max-w-2xl mx-auto"></p>{% endblock %}
			</div>
		</div>
	</section>

	{# ── Mobile Menu Drawer (hors du hero pour éviter le stacking context) ── #}
	{{ include('partials/_mobile_menu.html.twig') }}

	{# ── Contenu principal ───────────────────────────────────── #}
	<main class="relative z-10 mx-auto max-w-[1240px] px-8 lg:px-10 py-16 lg:py-20">
		{% block content %}{% endblock %}
	</main>

	{# ── Footer ──────────────────────────────────────────────── #}
	<footer class="border-t border-custom bg-custom-tertiary py-16 relative z-10">
		<div class="mx-auto grid max-w-[1240px] gap-12 px-6 md:grid-cols-4">
			<div class="md:col-span-1">
				<h3 class="mb-6 text-xs font-bold uppercase tracking-widest text-text-primary">COMMUNAUTÉ & RESSOURCES</h3>
				<p class="mb-4 text-sm text-text-secondary">Newsletter</p>
				{% for label, messages in app.flashes %}
					{% if label starts with 'newsletter_' %}
						{% for message in messages %}
							<div class="mb-3 rounded-lg px-3 py-2 text-xs {% if label == 'newsletter_success' %}bg-green-400/10 text-green-400{% elseif label == 'newsletter_error' %}bg-red-400/10 text-red-400{% else %}bg-yellow-400/10 text-yellow-400{% endif %}">
								{{ message }}
							</div>
						{% endfor %}
					{% endif %}
				{% endfor %}
				<form class="flex gap-2" action="{{ path('app_newsletter_subscribe') }}" method="post" data-turbo="false">
					<input type="hidden" name="_token" value="{{ csrf_token('newsletter_subscribe') }}">
					<input type="email" name="email" placeholder="Pour s'inscrire..." required class="w-full rounded-lg border border-custom bg-custom-secondary px-4 py-3 text-sm text-text-primary focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange transition-all">
					<button type="submit" class="rounded-lg bg-custom-orange px-4 py-3 text-xs font-bold text-gray-900 hover:bg-orange-600 transition-all" aria-label="S'inscrire">
						<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
					</button>
				</form>
			</div>
			<div>
				<h3 class="mb-6 text-xs font-bold uppercase tracking-widest text-text-primary">SOCIALS</h3>
				<div class="flex gap-4">
					<a href="https://www.facebook.com/laboiteachimere" target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-full bg-custom-secondary text-text-primary/60 transition-all hover:bg-blue-600 hover:text-text-primary hover:scale-110" aria-label="Facebook">
						<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
					</a>
					<span role="img" class="flex h-10 w-10 items-center justify-center rounded-full bg-custom-secondary text-text-primary/30 cursor-not-allowed" aria-label="Instagram (bientôt disponible)" title="Instagram (bientôt disponible)">
						<svg class="h-5 w-5" fill="currentColor" viewbox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
					</span>
					<span role="img" class="flex h-10 w-10 items-center justify-center rounded-full bg-custom-secondary text-text-primary/30 cursor-not-allowed" aria-label="YouTube (bientôt disponible)" title="YouTube (bientôt disponible)">
						<svg class="h-5 w-5" fill="currentColor" viewbox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
					</span>
				</div>
			</div>
			<div class="md:col-span-2">
				<h3 class="mb-6 text-xs font-bold uppercase tracking-widest text-text-primary">PAGES IMPORTANTES</h3>
				<div class="grid grid-cols-2 gap-4">
					<ul class="space-y-3 text-sm text-text-secondary">
						<li><a href="{{ path('app_nouvelles') }}" class="hover:text-text-primary transition-colors">Nouvelles</a></li>
						<li><a href="{{ path('app_qui_sommes_nous') }}" class="hover:text-text-primary transition-colors">Qui sommes-nous</a></li>
						<li><a href="{{ path('app_societes') }}" class="hover:text-text-primary transition-colors">Sociétés</a></li>
					</ul>
					<ul class="space-y-3 text-sm text-text-secondary">
						<li><a href="{{ path('app_evenements') }}" class="hover:text-text-primary transition-colors">Événements</a></li>
						<li><a href="{{ path('app_mentions_legales') }}" class="hover:text-text-primary transition-colors">Mentions légales</a></li>
						<li><a href="{{ path('app_contact') }}" class="hover:text-text-primary transition-colors">Contact</a></li>
						<li><button type="button" data-cookie-settings class="hover:text-text-primary transition-colors text-left">Gestion des cookies</button></li>
					</ul>
				</div>
			</div>
		</div>
		<div class="mx-auto mt-16 max-w-[1240px] border-t border-custom px-6 pt-8 text-center text-xs text-text-secondary">
			<p>&copy; {{ "now"|date("Y") }} LA BOÎTE À CHIMÈRE. Tous droits réservés.</p>
		</div>
	</footer>

{# ── Modale inscription (hors de tout stacking context) ── #}
{% if not app.user %}
	<div id="register-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center">
		<div id="register-overlay" class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
		<div class="relative z-10 w-full max-w-md mx-4 rounded-2xl border border-custom bg-custom-secondary shadow-2xl overflow-hidden">
			<div class="bg-custom-tertiary px-6 py-4 border-b border-custom flex items-center justify-between">
				<div>
					<span class="text-[9px] font-bold uppercase tracking-widest text-custom-orange">Nouveau membre</span>
					<h2 class="text-lg font-bold text-text-primary uppercase tracking-wide">Créer un compte</h2>
				</div>
				<button id="register-close" type="button" class="text-text-secondary hover:text-text-primary transition-colors p-1" aria-label="Fermer">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>
			<div class="px-6 py-5">
				{% for message in app.flashes('register_error') %}
					<div class="mb-3 rounded-lg bg-red-400/10 px-3 py-2 text-xs text-red-400">{{ message }}</div>
				{% endfor %}
				<form action="{{ path('app_register') }}" method="post" data-turbo="false" class="flex flex-col gap-4">
					<input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">
					<div>
						<label for="register-email" class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Email</label>
						<input type="email" id="register-email" name="email" required autocomplete="email" value="{{ app.request.query.get('email', '') }}" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange" placeholder="votre@email.com">
					</div>
					<div>
						<label for="register-username" class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Nom d'utilisateur</label>
						<input type="text" id="register-username" name="username" required minlength="3" autocomplete="username" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange" placeholder="VotreNom">
					</div>
					<div>
						<label for="register-password" class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Mot de passe</label>
						<div class="relative">
							<input type="password" id="register-password" name="password" required minlength="6" autocomplete="new-password" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 pr-10 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange" placeholder="6 caractères minimum">
							<button type="button" data-toggle-password="register-password" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-text-primary transition-colors" tabindex="-1" aria-label="Afficher le mot de passe">
								<svg class="w-5 h-5 eye-closed" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.5 6.5m3.378 3.378L6.5 6.5m0 0L3 3m3.5 3.5l10 10M17.5 17.5L21 21m-3.5-3.5l-10-10m13.043 4.51A9.953 9.953 0 0121 12c-1.275 4.057-5.065 7-9.543 7"/></svg>
								<svg class="w-5 h-5 eye-open hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
							</button>
						</div>
					</div>
					<div>
						<label for="register-password-confirm" class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Confirmer le mot de passe</label>
						<div class="relative">
							<input type="password" id="register-password-confirm" required minlength="6" autocomplete="new-password" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 pr-10 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange" placeholder="Répétez le mot de passe">
							<button type="button" data-toggle-password="register-password-confirm" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-text-primary transition-colors" tabindex="-1" aria-label="Afficher la confirmation du mot de passe">
								<svg class="w-5 h-5 eye-closed" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.5 6.5m3.378 3.378L6.5 6.5m0 0L3 3m3.5 3.5l10 10M17.5 17.5L21 21m-3.5-3.5l-10-10m13.043 4.51A9.953 9.953 0 0121 12c-1.275 4.057-5.065 7-9.543 7"/></svg>
								<svg class="w-5 h-5 eye-open hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
							</button>
						</div>
					</div>
					<p id="register-password-error" class="hidden text-xs text-red-400">Les mots de passe ne correspondent pas.</p>
					<button type="submit" class="w-full rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-gray-900 cursor-pointer hover:bg-orange-600 hover:scale-105 hover:shadow-xl hover:shadow-custom-orange/40 transition-all shadow-lg shadow-custom-orange/20">S'INSCRIRE</button>
				</form>
			</div>
		</div>
	</div>
{% endif %}
{% endblock %}
