							<button type="button" data-open-register class="w-full rounded-lg border border-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-custom-orange cursor-pointer hover:bg-custom-orange hover:text-gray-900 hover:scale-105 hover:shadow-lg hover:shadow-custom-orange/40 transition-all">S'INSCRIRE</button>
							<a href="{{ path('app_forgot_password_request') }}" class="block text-center text-xs text-text-secondary hover:text-custom-orange transition-colors mt-1">Mot de passe oublié ?</a>
						</form>
					</div>
