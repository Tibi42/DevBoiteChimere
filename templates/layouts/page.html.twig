			</nav>
			<div class="absolute bottom-10 left-8 right-8 text-center">
				<p class="text-[10px] uppercase tracking-widest text-text-secondary/60 font-bold">&copy; LA BOÎTE À CHIMÈRE</p>
			</div>
		</div>
	</div>

