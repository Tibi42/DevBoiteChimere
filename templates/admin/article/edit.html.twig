{% extends 'admin/layout.html.twig' %}

{% block title %}Modifier {{ article.title }} - La Boîte à Chimère{% endblock %}

{% block admin_body %}
	<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
	<style>
		.ql-toolbar {
			background-color: rgba(255, 255, 255, 0.05);
			border-color: rgba(255, 255, 255, 0.1) !important;
			border-top-left-radius: 8px;
			border-top-right-radius: 8px;
		}
		.ql-container {
			border-color: rgba(255, 255, 255, 0.1) !important;
			border-bottom-left-radius: 8px;
			border-bottom-right-radius: 8px;
			font-family: inherit;
			font-size: 14px;
			background-color: rgba(255, 255, 255, 0.02);
			color: #fff;
		}
		.ql-editor {
			min-height: 400px;
		}
		.ql-snow .ql-stroke {
			stroke: #a3a3a3;
		}
		.ql-snow .ql-fill {
			fill: #a3a3a3;
		}
		.ql-snow .ql-picker {
			color: #a3a3a3;
		}
		.ql-snow .ql-picker-options {
			background-color: #1a1a1a !important;
			border-color: rgba(255, 255, 255, 0.1) !important;
		}
	</style>

	<div class="min-h-screen mx-auto max-w-[1240px] px-4 sm:px-8 py-8">
		<a href="{{ path('app_admin_article_index') }}" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors mb-6">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
			Retour aux articles
		</a>

		<div class="flex flex-col xl:flex-row gap-8 items-start">
			<div class="w-full xl:max-w-2xl rounded-2xl border border-custom bg-custom-secondary p-6 lg:p-8 shadow-2xl glass-card">
				<h1 class="text-xl font-bold text-text-primary uppercase tracking-wide mb-6">Modifier l'article</h1>
				<div class="mb-6 p-4 rounded-xl bg-custom-tertiary/50 border border-custom">
					<span class="text-[9px] font-bold uppercase tracking-widest text-custom-orange">{{ article.tag }}</span>
					<p class="font-medium text-text-primary mt-1">{{ article.title }}</p>
					{% if article.url %}
						<p class="text-xs text-text-secondary mt-0.5">Lien : {{ article.url }}</p>
					{% endif %}
				</div>
				{{ include('admin/article/_form.html.twig', { form: form, button_label: 'Enregistrer', form_action: path('app_admin_article_edit', { id: article.id }) }) }}
			</div>
		</div>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
	<script>
		function initQuill() {
			var container = document.getElementById('editor-container');
			if (!container || container.classList.contains('ql-container')) {
				return;
			}

			if (typeof Quill === 'undefined') {
				setTimeout(initQuill, 50);
				return;
			}

			var toolbarOptions = [
				[{ 'header': [1, 2, 3, false] }],
				['bold', 'italic', 'underline', 'strike'],
				[{ 'list': 'ordered'}, { 'list': 'bullet' }],
				['link', 'clean']
			];

			var quill = new Quill('#editor-container', {
				theme: 'snow',
				modules: {
					toolbar: toolbarOptions
				}
			});

			var form = document.querySelector('form');
			var contentInput = document.querySelector('.hidden-content-editor');

			if (form && contentInput) {
				form.addEventListener('submit', function() {
					var html = quill.root.innerHTML;
					if (html === '<p><br></p>' || html === '<p></p>') {
						html = '';
					}
					contentInput.value = html;
				});
			}
		}

		initQuill();
		document.addEventListener('DOMContentLoaded', initQuill);
		document.addEventListener('turbo:load', initQuill);
	</script>
{% endblock %}
