{% extends 'admin/layout.html.twig' %}

{% block title %}Gestion des articles - La Boîte à Chimère{% endblock %}

{% block admin_body %}
	<div class="min-h-screen mx-auto max-w-[1240px] px-4 sm:px-8 py-8">
		<a href="{{ path('admin') }}" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors mb-6">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
			Retour au dashboard
		</a>

		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
			<h1 class="text-2xl font-bold text-text-primary uppercase tracking-wide">Gestion des articles</h1>
			<a href="{{ path('app_admin_article_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-custom-orange py-3 px-5 text-sm font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all shadow-lg shadow-custom-orange/20">
				<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
				Nouvel article
			</a>
		</div>

		{% if articles|length > 0 %}
			{# Vue mobile : cartes #}
			<div class="lg:hidden space-y-3">
				{% for article in articles %}
					<div class="rounded-xl border border-custom bg-custom-secondary p-4 shadow-lg glass-card {{ not article.active ? 'opacity-50' : '' }}">
						<div class="flex items-start justify-between gap-3 mb-2">
							<span class="font-medium text-text-primary text-sm">{{ article.title }}</span>
							<div class="flex items-center gap-2 shrink-0">
								{% if not article.active %}
									<span class="text-[9px] font-bold uppercase tracking-widest text-amber-400 bg-amber-400/10 px-2 py-0.5 rounded">Suspendu</span>
								{% endif %}
								<span class="text-[9px] font-bold uppercase tracking-widest text-custom-orange bg-custom-orange/10 px-2 py-0.5 rounded">{{ article.tag }}</span>
							</div>
						</div>
						<div class="flex flex-col gap-1 text-xs text-text-secondary mb-3">
							<span>Position : {{ article.position }}</span>
							<span>Image : {{ article.image }}</span>
							{% if article.url %}
								<span class="truncate">Lien : {{ article.url }}</span>
							{% endif %}
						</div>
						<div class="flex flex-wrap items-center gap-3 pt-2 border-t border-custom/50">
							<a href="{{ path('app_admin_article_edit', { id: article.id }) }}" class="text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors">Modifier</a>
							<form method="post" action="{{ path('app_admin_article_toggle', { id: article.id }) }}" class="contents">
								<input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ article.id) }}">
								<button type="submit" class="cursor-pointer text-[10px] font-bold uppercase tracking-wider {{ article.active ? 'text-amber-400 hover:text-amber-300' : 'text-emerald-400 hover:text-emerald-300' }} transition-colors">
									{{ article.active ? 'Suspendre' : 'Activer' }}
								</button>
							</form>
							<form method="post" action="{{ path('app_admin_article_delete', { id: article.id }) }}" class="contents" onsubmit="return confirm('Supprimer cet article ?');">
								<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
								<button type="submit" class="cursor-pointer text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Supprimer</button>
							</form>
						</div>
					</div>
				{% endfor %}
			</div>

			{# Vue desktop : tableau #}
			<div class="hidden lg:block rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card">
				<div class="overflow-x-auto">
					<table class="w-full text-left">
						<thead class="bg-custom-tertiary/50 border-b border-custom">
							<tr>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary w-16">Ordre</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary w-20">Image</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Titre</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Tag</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Lien</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Statut</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary text-right">Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for article in articles %}
								<tr class="border-b border-custom/50 hover:bg-white/5 transition-colors {{ not article.active ? 'opacity-50' : '' }}">
									<td class="px-4 py-3 text-sm text-text-secondary">{{ article.position }}</td>
									<td class="px-4 py-3">
										<div class="h-10 w-16 rounded overflow-hidden bg-custom-tertiary border border-custom">
											<img src="{{ asset('images/articles/' ~ article.image) }}" alt="" class="h-full w-full object-cover">
										</div>
									</td>
									<td class="px-4 py-3">
										<span class="font-medium text-text-primary">{{ article.title }}</span>
									</td>
									<td class="px-4 py-3">
										<span class="text-[9px] font-bold uppercase tracking-widest text-custom-orange bg-custom-orange/10 px-2 py-0.5 rounded">{{ article.tag }}</span>
									</td>
									<td class="px-4 py-3 text-sm text-text-secondary truncate max-w-[200px]">
										{{ article.url|default('-') }}
									</td>
									<td class="px-4 py-3">
										{% if article.active %}
											<span class="text-[9px] font-bold uppercase tracking-widest text-emerald-400 bg-emerald-400/10 px-2 py-0.5 rounded">Actif</span>
										{% else %}
											<span class="text-[9px] font-bold uppercase tracking-widest text-amber-400 bg-amber-400/10 px-2 py-0.5 rounded">Suspendu</span>
										{% endif %}
									</td>
									<td class="px-4 py-3 text-right whitespace-nowrap">
										<a href="{{ path('app_admin_article_edit', { id: article.id }) }}" class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors mr-3">Modifier</a>
										<form method="post" action="{{ path('app_admin_article_toggle', { id: article.id }) }}" class="inline">
											<input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ article.id) }}">
											<button type="submit" class="cursor-pointer text-[10px] font-bold uppercase tracking-wider {{ article.active ? 'text-amber-400 hover:text-amber-300' : 'text-emerald-400 hover:text-emerald-300' }} transition-colors mr-3">
												{{ article.active ? 'Suspendre' : 'Activer' }}
											</button>
										</form>
										<form method="post" action="{{ path('app_admin_article_delete', { id: article.id }) }}" class="inline" onsubmit="return confirm('Supprimer cet article ?');">
											<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
											<button type="submit" class="cursor-pointer text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Supprimer</button>
										</form>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		{% else %}
			<div class="rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card px-6 py-12 text-center">
				<p class="text-text-secondary mb-4">Aucun article personnalisé. La section "Dernières Chimères" de la page d'accueil affichera les articles par défaut jusqu'à ce que vous en ajoutiez.</p>
				<a href="{{ path('app_admin_article_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-custom-orange py-2.5 px-4 text-xs font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all">
					<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
					Ajouter un article
				</a>
			</div>
		{% endif %}
	</div>
{% endblock %}
