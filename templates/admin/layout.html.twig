{% extends 'base.html.twig' %}

{% block meta_description %}<meta name="robots" content="noindex, nofollow">{% endblock %}
{% block canonical %}{% endblock %}
{% block og_tags %}{% endblock %}
{% block jsonld %}{% endblock %}

{% block body %}
<div class="flex min-h-screen">

    {# ── Sidebar ── #}
    <aside class="hidden lg:flex flex-col w-56 shrink-0 border-r border-custom bg-custom-secondary">
        <div class="px-5 py-5 border-b border-custom">
            <a href="{{ path('admin') }}" class="text-xs font-extrabold uppercase tracking-widest text-custom-orange">
                La Boîte à Chimère
            </a>
            <p class="text-[10px] text-text-secondary mt-0.5">Administration</p>
        </div>

        <nav class="flex flex-col gap-1 p-3 flex-1">
            {% set current = app.request.attributes.get('_route') %}

            <a href="{{ path('admin') }}"
               class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-bold uppercase tracking-wider transition-colors
                      {{ current == 'admin' ? 'bg-custom-orange text-text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-white/5' }}">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Dashboard
            </a>

            <a href="{{ path('app_activity_index') }}"
               class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-bold uppercase tracking-wider transition-colors
                      {{ current starts with 'app_activity' ? 'bg-custom-orange text-text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-white/5' }}">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                Activités
            </a>

            <a href="{{ path('app_admin_carousel_index') }}"
               class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-bold uppercase tracking-wider transition-colors
                      {{ current starts with 'app_admin_carousel' ? 'bg-custom-orange text-text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-white/5' }}">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                Carousel
            </a>

            <a href="{{ path('app_admin_user_index') }}"
               class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-bold uppercase tracking-wider transition-colors
                      {{ current starts with 'app_admin_user' ? 'bg-custom-orange text-text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-white/5' }}">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Utilisateurs
            </a>

            <a href="{{ path('app_admin_newsletter_index') }}"
               class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-bold uppercase tracking-wider transition-colors
                      {{ current starts with 'app_admin_newsletter' ? 'bg-custom-orange text-text-primary' : 'text-text-secondary hover:text-text-primary hover:bg-white/5' }}">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Newsletter
            </a>

            <div class="flex-1"></div>

            <a href="{{ path('app_home') }}"
               class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-bold uppercase tracking-wider text-text-secondary hover:text-text-primary hover:bg-white/5 transition-colors">
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                Retour à la page d'accueil
            </a>
        </nav>
    </aside>

    {# ── Contenu principal ── #}
    <div class="flex-1 min-w-0">
        {% block admin_body %}{% endblock %}
    </div>

</div>
{% endblock %}
