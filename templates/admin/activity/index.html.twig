{% from 'components/_activity_badge.html.twig' import badge as activity_badge %}
{% extends 'base.html.twig' %}

{% block title %}Gestion des activités - La Boîte à Chimère{% endblock %}

{% block body %}
	<div class="min-h-screen mx-auto max-w-[1240px] px-4 sm:px-8 py-8">
		<a href="{{ path('admin') }}" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors mb-6">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
			Retour au dashboard
		</a>

		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
			<h1 class="text-2xl font-bold text-text-primary uppercase tracking-wide">Gestion des activités du calendrier</h1>
			<div class="flex items-center gap-3">
				<a href="{{ path('app_activity_export_csv', {status: currentStatus, type: currentType, location: currentLocation}) }}" class="inline-flex items-center gap-2 rounded-lg border border-custom py-3 px-5 text-sm font-extrabold uppercase tracking-widest text-text-secondary hover:text-text-primary hover:border-custom-orange transition-all">
					<svg class="h-5 w-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a2 2 0 002 2h14a2 2 0 002-2v-3"/></svg>
					Export CSV
				</a>
				<a href="{{ path('app_activity_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-custom-orange py-3 px-5 text-sm font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all shadow-lg shadow-custom-orange/20">
					<svg class="h-5 w-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
					Nouvelle activité
				</a>
			</div>
		</div>

		{# Filtres #}
		<div class="flex flex-col sm:flex-row sm:items-end gap-4 mb-6">
			{# Filtre status #}
			<div>
				<span class="block text-[9px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Statut</span>
				<div class="flex gap-1.5">
					<a href="{{ path('app_activity_index', {type: currentType, location: currentLocation}) }}"
					   class="px-3 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentStatus is null ? 'bg-custom-orange text-text-primary' : 'border border-custom text-text-secondary hover:text-text-primary' }}">
						Toutes
					</a>
					<a href="{{ path('app_activity_index', {status: 'pending', type: currentType, location: currentLocation}) }}"
					   class="px-3 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentStatus == 'pending' ? 'bg-custom-orange text-text-primary' : 'border border-custom text-text-secondary hover:text-text-primary' }}">
						En attente
					</a>
					<a href="{{ path('app_activity_index', {status: 'published', type: currentType, location: currentLocation}) }}"
					   class="px-3 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentStatus == 'published' ? 'bg-custom-orange text-text-primary' : 'border border-custom text-text-secondary hover:text-text-primary' }}">
						Publiées
					</a>
				</div>
			</div>
			{# Filtre type #}
			<div>
				<span class="block text-[9px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Type</span>
				<div class="flex flex-wrap gap-1.5">
					<a href="{{ path('app_activity_index', {status: currentStatus, location: currentLocation}) }}"
					   class="px-2.5 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentType is null ? 'bg-custom-orange text-text-primary' : 'border border-custom text-text-secondary hover:text-text-primary' }}">
						Tous
					</a>
					<a href="{{ path('app_activity_index', {status: currentStatus, type: 'JDS', location: currentLocation}) }}"
					   class="px-2.5 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentType == 'JDS' ? 'bg-emerald-500 text-white' : 'bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500/40' }}">
						JDS
					</a>
					<a href="{{ path('app_activity_index', {status: currentStatus, type: 'JDR', location: currentLocation}) }}"
					   class="px-2.5 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentType == 'JDR' ? 'bg-violet-500 text-white' : 'bg-violet-500/20 text-violet-400 hover:bg-violet-500/40' }}">
						JDR
					</a>
					<a href="{{ path('app_activity_index', {status: currentStatus, type: 'GN', location: currentLocation}) }}"
					   class="px-2.5 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentType == 'GN' ? 'bg-red-500 text-white' : 'bg-red-500/20 text-red-400 hover:bg-red-500/40' }}">
						GN
					</a>
					<a href="{{ path('app_activity_index', {status: currentStatus, type: 'JDF', location: currentLocation}) }}"
					   class="px-2.5 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentType == 'JDF' ? 'bg-sky-500 text-white' : 'bg-sky-500/20 text-sky-400 hover:bg-sky-500/40' }}">
						JDF
					</a>
					<a href="{{ path('app_activity_index', {status: currentStatus, type: 'AG', location: currentLocation}) }}"
					   class="px-2.5 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentType == 'AG' ? 'bg-amber-500 text-white' : 'bg-amber-500/20 text-amber-400 hover:bg-amber-500/40' }}">
						AG
					</a>
					<a href="{{ path('app_activity_index', {status: currentStatus, type: 'Play Test', location: currentLocation}) }}"
					   class="px-2.5 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentType == 'Play Test' ? 'bg-custom-orange text-white' : 'bg-custom-orange/20 text-custom-orange hover:bg-custom-orange/40' }}">
						Play Test
					</a>
				</div>
			</div>
			{# Filtre lieu #}
			<div>
				<span class="block text-[9px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Lieu</span>
				<div class="flex flex-wrap gap-1.5">
					<a href="{{ path('app_activity_index', {status: currentStatus, type: currentType}) }}"
					   class="px-2.5 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentLocation is null ? 'bg-custom-orange text-text-primary' : 'border border-custom text-text-secondary hover:text-text-primary' }}">
						Tous
					</a>
					<a href="{{ path('app_activity_index', {status: currentStatus, type: currentType, location: "L'auberge de jeunesse Yves Robert"}) }}"
					   class="px-2.5 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentLocation == "L'auberge de jeunesse Yves Robert" ? 'bg-cyan-500 text-white' : 'bg-cyan-500/20 text-cyan-400 hover:bg-cyan-500/40' }}">
						Auberge Yves Robert
					</a>
					<a href="{{ path('app_activity_index', {status: currentStatus, type: currentType, location: 'Le Natema'}) }}"
					   class="px-2.5 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors {{ currentLocation == 'Le Natema' ? 'bg-fuchsia-500 text-white' : 'bg-fuchsia-500/20 text-fuchsia-400 hover:bg-fuchsia-500/40' }}">
						Le Natema
					</a>
				</div>
			</div>
		</div>

		<div class="rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card">
			{% if activities|length > 0 %}
				<div class="overflow-x-auto">
					<table class="w-full text-left">
						<thead class="bg-custom-tertiary/50 border-b border-custom">
							<tr>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Date</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Titre</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Type</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Lieu</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Proposé par</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary text-right">Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for activity in activities %}
								<tr class="border-b border-custom/50 hover:bg-white/5 transition-colors {{ activity.status == 'pending' ? 'bg-custom-orange/5' : '' }}">
									<td class="px-4 py-3 text-sm text-text-primary whitespace-nowrap">
										{{ activity.startAt|date('d/m/Y') }}
									</td>
									<td class="px-4 py-3">
										<div class="flex items-center gap-2">
											<span class="font-medium text-text-primary">{{ activity.title }}</span>
											{% if activity.status == 'pending' %}
												<span class="bg-custom-orange text-white text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full shrink-0">
													En attente
												</span>
											{% endif %}
										</div>
									</td>
									<td class="px-4 py-3">
										{{ activity_badge(activity.type|default('—')) }}
									</td>
									<td class="px-4 py-3 text-sm text-text-secondary">{{ activity.location|default('—') }}</td>
									<td class="px-4 py-3 text-sm text-text-secondary">
										{% if activity.proposedBy %}
											<span class="text-text-secondary">{{ activity.proposedBy.email }}</span>
										{% else %}
											<span class="text-text-secondary/40">—</span>
										{% endif %}
									</td>
									<td class="px-4 py-3 text-right whitespace-nowrap">
										{% if activity.status == 'pending' %}
											<form method="post" action="{{ path('app_activity_approve', { id: activity.id }) }}" class="inline">
												<input type="hidden" name="_token" value="{{ csrf_token('approve' ~ activity.id) }}">
												<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-green-400 hover:text-green-300 transition-colors mr-3">Approuver</button>
											</form>
											<form method="post" action="{{ path('app_activity_reject', { id: activity.id }) }}" class="inline"
												  onsubmit="return confirm('Rejeter et supprimer cette proposition ?')">
												<input type="hidden" name="_token" value="{{ csrf_token('reject' ~ activity.id) }}">
												<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors mr-3">Rejeter</button>
											</form>
										{% else %}
											<a href="{{ path('app_activity_edit', { id: activity.id }) }}" class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors mr-3">Modifier</a>
											<a href="{{ path('app_activity_register', { id: activity.id }) }}" class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-text-primary transition-colors mr-3" target="_blank" rel="noopener">Voir inscription</a>
										{% endif %}
										<form method="post" action="{{ path('app_activity_delete', { id: activity.id }) }}" class="inline"
											  onsubmit="return confirm('Supprimer cette activité ? Les inscriptions associées seront aussi supprimées.')">
											<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ activity.id) }}">
											<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Supprimer</button>
										</form>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			{% else %}
				<div class="px-6 py-12 text-center">
					<p class="text-text-secondary mb-4">Aucune activité pour le moment.</p>
					<a href="{{ path('app_activity_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-custom-orange py-2.5 px-4 text-xs font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all">
						<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
						Créer une activité
					</a>
				</div>
			{% endif %}
		</div>
	</div>
{% endblock %}
