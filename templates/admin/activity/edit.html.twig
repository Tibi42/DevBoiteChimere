{% extends 'base.html.twig' %}

{% block title %}Modifier {{ activity.title }} - La Boîte à Chimère{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">
	<style>
		.flatpickr-input.altInput { width: 100%; padding: 0.75rem 1rem; border-radius: 0.5rem; border: 1px solid rgba(255,255,255,0.1); background: #1e293b; color: #f8fafc; }
	</style>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
	<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>
	<script>
		(function initActivityDatePicker() {
			function run() {
				var input = document.querySelector('.activity-date-picker');
				if (input && typeof flatpickr !== 'undefined' && !input._flatpickr) {
					flatpickr(input, {
						dateFormat: 'Y-m-d',
						altInput: true,
						altFormat: 'j F Y',
						locale: 'fr',
						allowInput: false
					});
				}
			}
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', run);
			} else {
				run();
			}
			document.addEventListener('turbo:load', run);
		})();
	</script>
{% endblock %}

{% block body %}
	<div class="min-h-screen mx-auto max-w-[1240px] px-4 sm:px-8 py-8">
		<a href="{{ path('app_activity_index') }}" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors mb-6">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
			Retour à la liste des activités
		</a>

		<div class="max-w-2xl rounded-2xl border border-custom bg-custom-secondary p-6 lg:p-8 shadow-2xl glass-card">
			<h1 class="text-xl font-bold text-text-primary uppercase tracking-wide mb-6">Modifier l'activité</h1>
			<div class="mb-6 p-4 rounded-xl bg-custom-tertiary/50 border border-custom">
				<span class="text-[9px] font-bold uppercase tracking-widest text-custom-orange">{{ activity.type|default('Événement') }}</span>
				<p class="font-medium text-text-primary mt-1">{{ activity.title }}</p>
				<p class="text-sm text-text-secondary mt-0.5">{{ activity.startAt|date('d/m/Y') }}</p>
			</div>
			{{ include('admin/activity/_form.html.twig', { form: form, button_label: 'Enregistrer' }) }}
		</div>
	</div>
{% endblock %}
