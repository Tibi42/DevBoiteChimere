{% from 'components/_activity_badge.html.twig' import badge as activity_badge %}
{% extends 'base.html.twig' %}

{% block title %}Inscrits — {{ activity.title }} - La Boîte à Chimère{% endblock %}

{% block body %}
	<div class="min-h-screen mx-auto max-w-[1240px] px-4 sm:px-8 py-8">
		<a href="{{ path('app_activity_index') }}" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors mb-6">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
			Retour aux activités
		</a>

		<div class="mb-8">
			<div class="flex items-center gap-3 mb-2">
				{{ activity_badge(activity.type|default('—')) }}
				<span class="text-sm text-text-secondary">{{ activity.startAt|date('d/m/Y') }}</span>
			</div>
			<h1 class="text-2xl font-bold text-text-primary uppercase tracking-wide mb-1">{{ activity.title }}</h1>
			{% if activity.location %}
				<p class="text-sm text-text-secondary flex items-center gap-1">
					<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
					{{ activity.location }}
				</p>
			{% endif %}
			<p class="text-sm text-text-secondary mt-1">
				{{ inscriptions|length }} inscrit{{ inscriptions|length > 1 ? 's' : '' }}{% if activity.maxParticipants %} / {{ activity.maxParticipants }} places{% endif %}
			</p>
		</div>

		{% if inscriptions|length > 0 %}
			{# Vue mobile : cartes #}
			<div class="lg:hidden space-y-3">
				{% for inscription in inscriptions %}
					<div class="rounded-xl border border-custom bg-custom-secondary p-4 glass-card">
						<div class="flex items-center justify-between mb-1">
							<span class="font-medium text-text-primary text-sm">{{ inscription.participantName }}</span>
							<span class="text-[10px] text-text-secondary">{{ inscription.createdAt|date('d/m/Y H:i') }}</span>
						</div>
						<a href="mailto:{{ inscription.participantEmail }}" class="text-xs text-custom-orange hover:text-orange-400 transition-colors">{{ inscription.participantEmail }}</a>
					</div>
				{% endfor %}
			</div>

			{# Vue desktop : tableau #}
			<div class="hidden lg:block rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card">
				<table class="w-full text-left">
					<thead class="bg-custom-tertiary/50 border-b border-custom">
						<tr>
							<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary w-12">#</th>
							<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Nom</th>
							<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Email</th>
							<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Date d'inscription</th>
						</tr>
					</thead>
					<tbody>
						{% for inscription in inscriptions %}
							<tr class="border-b border-custom/50 hover:bg-white/5 transition-colors">
								<td class="px-4 py-3 text-sm text-text-secondary">{{ loop.index }}</td>
								<td class="px-4 py-3 text-sm font-medium text-text-primary">{{ inscription.participantName }}</td>
								<td class="px-4 py-3 text-sm">
									<a href="mailto:{{ inscription.participantEmail }}" class="text-custom-orange hover:text-orange-400 transition-colors">{{ inscription.participantEmail }}</a>
								</td>
								<td class="px-4 py-3 text-sm text-text-secondary">{{ inscription.createdAt|date('d/m/Y à H:i') }}</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% else %}
			<div class="rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card px-6 py-12 text-center">
				<p class="text-text-secondary">Aucun inscrit pour cette activité.</p>
			</div>
		{% endif %}
	</div>
{% endblock %}
