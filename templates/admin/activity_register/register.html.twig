{% extends 'base.html.twig' %}

{% block title %}S'inscrire - {{ activity.title }} - La Boîte à Chimère{% endblock %}

{% block body %}
	{# Overlay identique à la modale du calendrier #}
	<div class="fixed inset-0 z-[9999] bg-black/70 flex items-start justify-center p-4 pt-20 overflow-y-auto"
		 style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999">
		<div class="glass-card rounded-2xl border border-custom shadow-2xl w-11/12 max-w-xl relative p-6">
			{% include 'admin/activity_register/_register_frame.html.twig' %}
		</div>
	</div>
	<script>
		// Accès direct : les boutons data-modal-close redirigent vers l'accueil
		document.addEventListener('click', function(e) {
			if (e.target.closest('[data-modal-close]')) {
				e.preventDefault();
				window.location.href = '{{ path('app_home') }}';
			}
		});
	</script>
{% endblock %}
