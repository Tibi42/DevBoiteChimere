{% extends 'admin/layout.html.twig' %}

{% block title %}Modifier {{ slide.title }} - Carousel - La Boîte à Chimère{% endblock %}

{% block admin_body %}
	<div class="min-h-screen mx-auto max-w-[1240px] px-4 sm:px-8 py-8">
		<a href="{{ path('app_admin_carousel_index') }}" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors mb-6">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
			Retour au carousel
		</a>

		<div data-controller="carousel-preview" class="flex flex-col xl:flex-row gap-8 items-start">
			<div class="w-full xl:max-w-2xl rounded-2xl border border-custom bg-custom-secondary p-6 lg:p-8 shadow-2xl glass-card">
				<h1 class="text-xl font-bold text-text-primary uppercase tracking-wide mb-6">Modifier la slide</h1>
				<div class="mb-6 p-4 rounded-xl bg-custom-tertiary/50 border border-custom">
					<span class="text-[9px] font-bold uppercase tracking-widest {{ slide.tagColor }}">{{ slide.tag }}</span>
					<p class="font-medium text-text-primary mt-1">{{ slide.title }}</p>
					<p class="text-sm text-text-secondary mt-0.5">{{ slide.date }}</p>
				</div>
				{{ include('admin/carousel/_form.html.twig', { form: form, button_label: 'Enregistrer', form_action: path('app_admin_carousel_edit', { id: slide.id }) }) }}
			</div>

			<div class="w-full xl:w-80 xl:sticky xl:top-8">
				<div class="rounded-2xl border border-custom bg-custom-secondary p-5 shadow-xl glass-card">
					<h2 class="text-[10px] font-bold uppercase tracking-widest text-text-secondary mb-4">Aperçu</h2>
					<div class="rounded-xl border border-custom overflow-hidden">
						<div class="group flex flex-col gap-3 p-4 hover:bg-white/5 transition-colors">
							<div>
								<span data-carousel-preview-target="previewTag" class="text-[9px] font-bold uppercase tracking-[0.2em] {{ slide.tagColor }}">{{ slide.tag }}</span>
								<p data-carousel-preview-target="previewTitle" class="text-base font-bold text-text-primary mt-0.5 leading-tight">{{ slide.title }}</p>
								<p data-carousel-preview-target="previewDate" class="text-xs text-text-secondary mt-1">{{ slide.date }}</p>
							</div>
							<span data-carousel-preview-target="previewBtn" class="text-center rounded-lg {{ slide.btnClass }} px-4 py-2 text-[10px] font-bold uppercase tracking-wider text-gray-900 shadow-lg transition-all">{{ slide.btnText }}</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
