{% extends 'admin/layout.html.twig' %}

{% block title %}Newsletter - La Boîte à Chimère{% endblock %}

{% block admin_body %}
	<div class="min-h-screen mx-auto max-w-[1240px] px-4 sm:px-8 py-8">
		<a href="{{ path('admin') }}" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors mb-6">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
			Retour au dashboard
		</a>

		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
			<h1 class="text-2xl font-bold text-text-primary uppercase tracking-wide">Newsletter</h1>
			<a href="{{ path('app_admin_newsletter_export') }}" class="inline-flex items-center gap-2 rounded-lg bg-custom-orange py-3 px-5 text-sm font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all shadow-lg shadow-custom-orange/20">
				<svg class="h-5 w-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
				Exporter CSV
			</a>
		</div>

		<div class="grid grid-cols-3 gap-4 mb-8">
			<div class="rounded-xl border border-custom bg-custom-secondary p-4 text-center glass-card">
				<p class="text-2xl font-bold text-green-400">{{ countConfirmed }}</p>
				<p class="text-[10px] font-bold uppercase tracking-wider text-text-secondary mt-1">Confirmés</p>
			</div>
			<div class="rounded-xl border border-custom bg-custom-secondary p-4 text-center glass-card">
				<p class="text-2xl font-bold text-yellow-400">{{ countPending }}</p>
				<p class="text-[10px] font-bold uppercase tracking-wider text-text-secondary mt-1">En attente</p>
			</div>
			<div class="rounded-xl border border-custom bg-custom-secondary p-4 text-center glass-card">
				<p class="text-2xl font-bold text-red-400">{{ countUnsubscribed }}</p>
				<p class="text-[10px] font-bold uppercase tracking-wider text-text-secondary mt-1">Désinscrits</p>
			</div>
		</div>

		{% if subscribers|length > 0 %}
			{# Vue mobile : cartes #}
			<div class="lg:hidden space-y-3">
				{% for subscriber in subscribers %}
					<div class="rounded-xl border border-custom bg-custom-secondary p-4 shadow-lg glass-card">
						<div class="flex items-start justify-between gap-3 mb-2">
							<span class="font-medium text-text-primary text-sm">{{ subscriber.email }}</span>
							{% if subscriber.status == 'confirmed' %}
								<span class="text-[9px] font-bold uppercase tracking-widest text-green-400 bg-green-400/10 px-2 py-0.5 rounded shrink-0">Confirmé</span>
							{% elseif subscriber.status == 'pending' %}
								<span class="text-[9px] font-bold uppercase tracking-widest text-yellow-400 bg-yellow-400/10 px-2 py-0.5 rounded shrink-0">En attente</span>
							{% else %}
								<span class="text-[9px] font-bold uppercase tracking-widest text-red-400 bg-red-400/10 px-2 py-0.5 rounded shrink-0">Désinscrit</span>
							{% endif %}
						</div>
						<div class="flex flex-col gap-1 text-xs text-text-secondary mb-3">
							<span>Inscrit le {{ subscriber.createdAt|date('d/m/Y à H:i') }}</span>
							{% if subscriber.confirmedAt %}
								<span>Confirmé le {{ subscriber.confirmedAt|date('d/m/Y à H:i') }}</span>
							{% endif %}
						</div>
						<div class="flex items-center pt-2 border-t border-custom/50">
							<form method="post" action="{{ path('app_admin_newsletter_delete', { id: subscriber.id }) }}" class="contents" onsubmit="return confirm('Supprimer cet abonné ?');">
								<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ subscriber.id) }}">
								<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Supprimer</button>
							</form>
						</div>
					</div>
				{% endfor %}
			</div>

			{# Vue desktop : tableau #}
			<div class="hidden lg:block rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card">
				<div class="overflow-x-auto">
					<table class="w-full text-left">
						<thead class="bg-custom-tertiary/50 border-b border-custom">
							<tr>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Email</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Statut</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Inscription</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Confirmation</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary text-right">Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for subscriber in subscribers %}
								<tr class="border-b border-custom/50 hover:bg-white/5 transition-colors">
									<td class="px-4 py-3">
										<span class="font-medium text-text-primary">{{ subscriber.email }}</span>
									</td>
									<td class="px-4 py-3">
										{% if subscriber.status == 'confirmed' %}
											<span class="text-[9px] font-bold uppercase tracking-widest text-green-400 bg-green-400/10 px-2 py-0.5 rounded">Confirmé</span>
										{% elseif subscriber.status == 'pending' %}
											<span class="text-[9px] font-bold uppercase tracking-widest text-yellow-400 bg-yellow-400/10 px-2 py-0.5 rounded">En attente</span>
										{% else %}
											<span class="text-[9px] font-bold uppercase tracking-widest text-red-400 bg-red-400/10 px-2 py-0.5 rounded">Désinscrit</span>
										{% endif %}
									</td>
									<td class="px-4 py-3 text-sm text-text-secondary">{{ subscriber.createdAt|date('d/m/Y H:i') }}</td>
									<td class="px-4 py-3 text-sm text-text-secondary">{{ subscriber.confirmedAt ? subscriber.confirmedAt|date('d/m/Y H:i') : '—' }}</td>
									<td class="px-4 py-3 text-right">
										<form method="post" action="{{ path('app_admin_newsletter_delete', { id: subscriber.id }) }}" class="inline" onsubmit="return confirm('Supprimer cet abonné ?');">
											<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ subscriber.id) }}">
											<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Supprimer</button>
										</form>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		{% else %}
			<div class="rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card px-6 py-12 text-center">
				<p class="text-text-secondary">Aucun abonné pour le moment.</p>
			</div>
		{% endif %}
	</div>
{% endblock %}
