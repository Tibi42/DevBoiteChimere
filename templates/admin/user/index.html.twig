{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs - La Boîte à Chimère{% endblock %}

{% block body %}
	<div class="min-h-screen mx-auto max-w-[1240px] px-4 sm:px-8 py-8">
		<a href="{{ path('admin') }}" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors mb-6">
			<svg class="h-4 w-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
			Retour au dashboard
		</a>

		{% for type, messages in app.flashes %}
			{% for message in messages %}
				<div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium
					{{ type == 'success' ? 'bg-emerald-500/10 border border-emerald-500/30 text-emerald-400' : '' }}
					{{ type == 'error' ? 'bg-red-500/10 border border-red-500/30 text-red-400' : '' }}
					{{ type == 'warning' ? 'bg-amber-500/10 border border-amber-500/30 text-amber-400' : '' }}">
					{{ message }}
				</div>
			{% endfor %}
		{% endfor %}

		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
			<h1 class="text-2xl font-bold text-text-primary uppercase tracking-wide">Gestion des utilisateurs</h1>
			<a href="{{ path('app_admin_user_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-custom-orange py-3 px-5 text-sm font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all shadow-lg shadow-custom-orange/20">
				<svg class="h-5 w-5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
				Nouvel utilisateur
			</a>
		</div>

		{% if users|length > 0 %}
			{# Vue mobile : cartes #}
			<div class="lg:hidden space-y-3">
				{% for user in users %}
					{% set isSuperAdmin = 'ROLE_SUPER_ADMIN' in user.roles %}
					<div class="rounded-xl border border-custom bg-custom-secondary p-4 shadow-lg glass-card {{ user == app.user ? 'border-custom-orange/30 bg-custom-orange/5' : '' }} {{ user.suspended ? 'opacity-50' : '' }}">
						<div class="flex items-start justify-between gap-3 mb-2">
							<div class="flex items-center gap-2 flex-wrap">
								<span class="font-medium text-text-primary text-sm">{{ user.username }}</span>
								{% if user == app.user %}
									<span class="text-[9px] font-bold uppercase tracking-widest text-custom-orange px-1.5 py-0.5 rounded bg-custom-orange/10">Vous</span>
								{% endif %}
								{% if user.suspended %}
									<span class="text-[9px] font-bold uppercase tracking-widest text-red-400 px-1.5 py-0.5 rounded bg-red-400/10">Suspendu</span>
								{% endif %}
							</div>
							<div>
								{% for role in user.roles %}
									{% if role != 'ROLE_USER' %}
										<span class="text-[9px] font-bold uppercase tracking-widest px-2 py-0.5 rounded {{ role == 'ROLE_SUPER_ADMIN' ? 'text-purple-400 bg-purple-400/10' : 'text-custom-orange bg-custom-orange/10' }}">
											{{ role == 'ROLE_SUPER_ADMIN' ? 'Super Admin' : 'Admin' }}
										</span>
									{% endif %}
								{% else %}
									<span class="text-[9px] font-bold uppercase tracking-widest text-text-secondary px-2 py-0.5 rounded bg-white/5">Utilisateur</span>
								{% endfor %}
							</div>
						</div>
						<p class="text-xs text-text-secondary mb-3">{{ user.email }}</p>
						<div class="flex flex-wrap items-center gap-3 pt-2 border-t border-custom/50">
							{% if not isSuperAdmin or is_granted('ROLE_SUPER_ADMIN') %}
								<a href="{{ path('app_admin_user_edit', { id: user.id }) }}" class="text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors">Modifier</a>
							{% endif %}
							{% if user != app.user and (not isSuperAdmin or is_granted('ROLE_SUPER_ADMIN')) %}
								<form method="post" action="{{ path('app_admin_user_suspend', { id: user.id }) }}" class="contents" onsubmit="return confirm('{{ user.suspended ? 'Réactiver' : 'Suspendre' }} l\'utilisateur {{ user.email }} ?');">
									<input type="hidden" name="_token" value="{{ csrf_token('suspend' ~ user.id) }}">
									<button type="submit" class="text-[10px] font-bold uppercase tracking-wider {{ user.suspended ? 'text-emerald-400 hover:text-emerald-300' : 'text-amber-400 hover:text-amber-300' }} transition-colors">{{ user.suspended ? 'Réactiver' : 'Suspendre' }}</button>
								</form>
								<form method="post" action="{{ path('app_admin_user_delete', { id: user.id }) }}" class="contents" onsubmit="return confirm('Supprimer l\'utilisateur {{ user.email }} ?');">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
									<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Supprimer</button>
								</form>
							{% endif %}
						</div>
					</div>
				{% endfor %}
			</div>

			{# Vue desktop : tableau #}
			<div class="hidden lg:block rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card">
				<div class="overflow-x-auto">
					<table class="w-full text-left">
						<thead class="bg-custom-tertiary/50 border-b border-custom">
							<tr>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Utilisateur</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Email</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary">Rôles</th>
								<th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-text-secondary text-right">Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for user in users %}
								{% set isSuperAdmin = 'ROLE_SUPER_ADMIN' in user.roles %}
								<tr class="border-b border-custom/50 hover:bg-white/5 transition-colors {{ user == app.user ? 'bg-custom-orange/5' : '' }} {{ user.suspended ? 'opacity-50' : '' }}">
									<td class="px-4 py-3">
										<span class="font-medium text-text-primary">{{ user.username }}</span>
										{% if user == app.user %}
											<span class="ml-2 text-[9px] font-bold uppercase tracking-widest text-custom-orange px-1.5 py-0.5 rounded bg-custom-orange/10">Vous</span>
										{% endif %}
										{% if user.suspended %}
											<span class="ml-2 text-[9px] font-bold uppercase tracking-widest text-red-400 px-1.5 py-0.5 rounded bg-red-400/10">Suspendu</span>
										{% endif %}
									</td>
									<td class="px-4 py-3 text-sm text-text-secondary">{{ user.email }}</td>
									<td class="px-4 py-3">
										{% for role in user.roles %}
											{% if role != 'ROLE_USER' %}
												<span class="text-[9px] font-bold uppercase tracking-widest px-2 py-0.5 rounded
													{{ role == 'ROLE_SUPER_ADMIN' ? 'text-purple-400 bg-purple-400/10' : 'text-custom-orange bg-custom-orange/10' }}">
													{{ role == 'ROLE_SUPER_ADMIN' ? 'Super Admin' : 'Admin' }}
												</span>
											{% endif %}
										{% else %}
											<span class="text-[9px] font-bold uppercase tracking-widest text-text-secondary px-2 py-0.5 rounded bg-white/5">Utilisateur</span>
										{% endfor %}
									</td>
									<td class="px-4 py-3 text-right whitespace-nowrap">
										{% if not isSuperAdmin or is_granted('ROLE_SUPER_ADMIN') %}
											<a href="{{ path('app_admin_user_edit', { id: user.id }) }}" class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-custom-orange hover:text-orange-400 transition-colors mr-3">Modifier</a>
										{% endif %}
										{% if user != app.user and (not isSuperAdmin or is_granted('ROLE_SUPER_ADMIN')) %}
											<form method="post" action="{{ path('app_admin_user_suspend', { id: user.id }) }}" class="inline" onsubmit="return confirm('{{ user.suspended ? 'Réactiver' : 'Suspendre' }} l\'utilisateur {{ user.email }} ?');">
												<input type="hidden" name="_token" value="{{ csrf_token('suspend' ~ user.id) }}">
												<button type="submit" class="text-[10px] font-bold uppercase tracking-wider {{ user.suspended ? 'text-emerald-400 hover:text-emerald-300' : 'text-amber-400 hover:text-amber-300' }} transition-colors mr-3">{{ user.suspended ? 'Réactiver' : 'Suspendre' }}</button>
											</form>
											<form method="post" action="{{ path('app_admin_user_delete', { id: user.id }) }}" class="inline" onsubmit="return confirm('Supprimer l\'utilisateur {{ user.email }} ?');">
												<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
												<button type="submit" class="text-[10px] font-bold uppercase tracking-wider text-red-400 hover:text-red-300 transition-colors">Supprimer</button>
											</form>
										{% endif %}
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		{% else %}
			<div class="rounded-2xl border border-custom bg-custom-secondary overflow-hidden shadow-xl glass-card px-6 py-12 text-center">
				<p class="text-text-secondary mb-4">Aucun utilisateur pour le moment.</p>
				<a href="{{ path('app_admin_user_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-custom-orange py-2.5 px-4 text-xs font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 transition-all">
					Créer un utilisateur
				</a>
			</div>
		{% endif %}
	</div>
{% endblock %}
