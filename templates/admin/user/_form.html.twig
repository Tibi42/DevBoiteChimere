{{ form_start(form, { attr: { class: 'space-y-4' } }) }}
	{% if form.vars.submitted and not form.vars.valid %}
		<div class="px-4 py-3 rounded-lg text-sm bg-red-500/10 border border-red-500/30 text-red-400">
			<p class="font-bold mb-1">Le formulaire contient des erreurs :</p>
			{{ form_errors(form) }}
			{% for child in form %}
				{% if not child.vars.valid %}
					<p>→ <strong>{{ child.vars.label }}</strong> :
					{% for error in child.vars.errors %}{{ error.message }}{% endfor %}
					</p>
				{% endif %}
			{% endfor %}
		</div>
	{% endif %}
	<div>
		{{ form_label(form.email) }}
		{{ form_widget(form.email) }}
		<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.email) }}</div>
	</div>
	<div>
		{{ form_label(form.username) }}
		{{ form_widget(form.username) }}
		<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.username) }}</div>
	</div>
	<div>
		{{ form_label(form.roles, null, { label_attr: { class: 'block text-sm font-medium text-text-secondary mb-2' } }) }}
		<div class="flex flex-wrap gap-4">
			{% for child in form.roles %}
				<label class="flex items-center gap-2 cursor-pointer group">
					{{ form_widget(child, { attr: { class: 'w-4 h-4 rounded border-custom accent-custom-orange cursor-pointer' } }) }}
					<span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">{{ child.vars.label }}</span>
				</label>
			{% endfor %}
		</div>
		<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.roles) }}</div>
	</div>
	{% if form.plainPassword is defined %}
	<div>
		{{ form_label(form.plainPassword) }}
		<div class="relative">
			{{ form_widget(form.plainPassword) }}
			<button type="button" onclick="togglePassword(this)" class="absolute inset-y-0 right-0 flex items-center pr-3 text-text-secondary hover:text-text-primary transition-colors cursor-pointer" tabindex="-1">
				<svg class="h-5 w-5 eye-on" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
				</svg>
				<svg class="h-5 w-5 eye-off hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
				</svg>
			</button>
		</div>
		<div class="text-amber-400 text-xs mt-1">{{ form_errors(form.plainPassword) }}</div>
	</div>
	{% endif %}
	<div class="flex flex-wrap gap-3 pt-2">
		<button type="submit" class="cursor-pointer rounded-lg bg-custom-orange py-3 px-6 text-sm font-extrabold uppercase tracking-widest text-text-primary hover:bg-orange-600 hover:scale-105 hover:shadow-xl hover:shadow-custom-orange/40 transition-all shadow-lg shadow-custom-orange/20">
			{{ button_label|default('Enregistrer') }}
		</button>
		<a href="{{ path('app_admin_user_index') }}" class="rounded-lg border border-custom bg-custom-secondary py-3 px-6 text-sm font-bold uppercase tracking-wider text-text-secondary hover:text-text-primary hover:border-custom-orange transition-all">
			Annuler
		</a>
	</div>
{{ form_end(form) }}
