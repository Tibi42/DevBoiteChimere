{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content %}
<div class="row g-4 mt-2">

    <div class="col-12">
        <h1 class="h3 mb-0">Tableau de bord</h1>
        <p class="text-muted small mt-1">La Boîte à Chimère — Administration</p>
    </div>

    {# En attente d'approbation #}
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_activity_index', { status: 'pending' }) }}" class="card h-100 text-decoration-none shadow-sm border-0" style="transition: transform .15s; background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">⏳</span>
                    <div>
                        <div class="fw-bold fs-5">En attente</div>
                        <div class="text-muted small">Événements à approuver</div>
                    </div>
                </div>
                <div class="mt-auto d-flex justify-content-between align-items-end">
                    <div class="fw-extrabold display-6" style="line-height: 1.1;">{{ pendingActivitiesCount|default(0) }}</div>
                    <span class="badge" style="background:#f8742c;">Voir →</span>
                </div>
            </div>
        </a>
    </div>

    {# Dernières inscriptions #}
    <div class="col-md-6 col-xl-4">
        <div class="card h-100 border-0" style="background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">⏱️</span>
                    <div>
                        <div class="fw-bold fs-5">Dernier inscrit</div>
                        <div class="text-muted small">10 dernières inscriptions</div>
                    </div>
                </div>

                {% if latestInscriptions|length > 0 %}
                    <div class="mt-auto d-flex flex-column gap-2">
                        {% for inscription in latestInscriptions %}
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div class="text-truncate">
                                    <div class="fw-semibold" style="font-size: .9rem;">
                                        {{ inscription.participantName|default(inscription.participantEmail) }}
                                    </div>
                                    <div class="text-muted small">
                                        Activité : {{ inscription.activity.title|default('—') }}
                                    </div>
                                </div>
                                <div class="text-muted small text-nowrap">
                                    {{ inscription.createdAt|date('d/m H:i') }}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="mt-auto text-muted small">Aucune inscription pour le moment.</div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Top proposants #}
    <div class="col-md-6 col-xl-4">
        <div class="card h-100 border-0" style="background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">🏆</span>
                    <div>
                        <div class="fw-bold fs-5">Top proposants</div>
                        <div class="text-muted small">Mois en cours</div>
                    </div>
                </div>

                {% if topProposers|length > 0 %}
                    <div class="mt-auto d-flex flex-column gap-2">
                        {% for proposer in topProposers %}
                            <div class="d-flex justify-content-between align-items-center gap-3">
                                <div class="text-truncate">
                                    <span class="fw-bold">
                                        {{ proposer.username|default(proposer.email)|default('—') }}
                                    </span>
                                </div>
                                <span class="badge" style="background:#f8742c;">{{ proposer.activityCount }}</span>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="mt-auto text-muted small">Aucune activité proposée sur la période.</div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Derniers inscrits (membres) #}
    <div class="col-md-6 col-xl-4">
        <div class="card h-100 border-0" style="background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">👥</span>
                    <div>
                        <div class="fw-bold fs-5">Derniers inscrits</div>
                        <div class="text-muted small">Nouveaux membres</div>
                    </div>
                </div>

                {% if latestUsers|length > 0 %}
                    <div class="mt-auto d-flex flex-column gap-2">
                        {% for user in latestUsers %}
                            <div class="d-flex justify-content-between align-items-center gap-3">
                                <div class="text-truncate">
                                    <div class="fw-semibold" style="font-size: .9rem;">{{ user.username }}</div>
                                    <div class="text-muted small">{{ user.email }}</div>
                                </div>
                                {% if 'ROLE_ADMIN' in user.roles or 'ROLE_SUPER_ADMIN' in user.roles %}
                                    <span class="badge" style="background:#f8742c;">Admin</span>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="mt-auto text-muted small">Aucun membre pour le moment.</div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Activités #}
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_activity_index') }}" class="card h-100 text-decoration-none shadow-sm border-0" style="transition: transform .15s; background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">📅</span>
                    <div>
                        <div class="fw-bold fs-5">Activités</div>
                        <div class="text-muted small">Calendrier des événements</div>
                    </div>
                </div>
                <div class="mt-auto">
                    <span class="badge" style="background:#f8742c;">Gérer →</span>
                </div>
            </div>
        </a>
    </div>

    {# Carousel #}
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_admin_carousel_index') }}" class="card h-100 text-decoration-none shadow-sm border-0" style="transition: transform .15s; background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">🎠</span>
                    <div>
                        <div class="fw-bold fs-5">Carousel</div>
                        <div class="text-muted small">Slides de la page d'accueil</div>
                    </div>
                </div>
                <div class="mt-auto">
                    <span class="badge" style="background:#f8742c;">Gérer →</span>
                </div>
            </div>
        </a>
    </div>

    {# Utilisateurs #}
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_admin_user_index') }}" class="card h-100 text-decoration-none shadow-sm border-0" style="transition: transform .15s; background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">👥</span>
                    <div>
                        <div class="fw-bold fs-5">Utilisateurs</div>
                        <div class="text-muted small">Comptes et rôles</div>
                    </div>
                </div>
                <div class="mt-auto">
                    <span class="badge" style="background:#f8742c;">Gérer →</span>
                </div>
            </div>
        </a>
    </div>

    {# Newsletter #}
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_admin_newsletter_index') }}" class="card h-100 text-decoration-none shadow-sm border-0" style="transition: transform .15s; background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">📧</span>
                    <div>
                        <div class="fw-bold fs-5">Newsletter</div>
                        <div class="text-muted small">Gestion des abonnés</div>
                    </div>
                </div>
                <div class="mt-auto d-flex justify-content-between align-items-end">
                    <div>
                        <span class="fw-bold fs-4" style="color: #22c55e;">{{ newsletterConfirmed|default(0) }}</span>
                        <span class="text-muted small">confirmés</span>
                        {% if newsletterPending|default(0) > 0 %}
                            <span class="ms-2 fw-bold" style="color: #eab308;">{{ newsletterPending }}</span>
                            <span class="text-muted small">en attente</span>
                        {% endif %}
                    </div>
                    <span class="badge" style="background:#f8742c;">Gérer →</span>
                </div>
            </div>
        </a>
    </div>

    {# Retour site #}
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_home') }}" class="card h-100 text-decoration-none shadow-sm border-0" style="transition: transform .15s; background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">🌐</span>
                    <div>
                        <div class="fw-bold fs-5">Site public</div>
                        <div class="text-muted small">Retour à la page d'accueil</div>
                    </div>
                </div>
                <div class="mt-auto">
                    <span class="badge bg-secondary">Voir →</span>
                </div>
            </div>
        </a>
    </div>

</div>
{% endblock %}
