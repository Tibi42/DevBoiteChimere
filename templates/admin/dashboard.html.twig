{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content %}
<div class="row g-4 mt-2">

    <div class="col-12">
        <h1 class="h3 mb-0">Tableau de bord</h1>
        <p class="text-muted small mt-1">La Boîte à Chimère — Administration</p>
    </div>

    {# Activités #}
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_activity_index') }}" class="card h-100 text-decoration-none shadow-sm border-0" style="transition: transform .15s; background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">📅</span>
                    <div>
                        <div class="fw-bold fs-5">Activités</div>
                        <div class="text-muted small">Calendrier des événements</div>
                    </div>
                </div>
                <div class="mt-auto">
                    <span class="badge" style="background:#f8742c;">Gérer →</span>
                </div>
            </div>
        </a>
    </div>

    {# Carousel #}
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_admin_carousel_index') }}" class="card h-100 text-decoration-none shadow-sm border-0" style="transition: transform .15s; background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">🎠</span>
                    <div>
                        <div class="fw-bold fs-5">Carousel</div>
                        <div class="text-muted small">Slides de la page d'accueil</div>
                    </div>
                </div>
                <div class="mt-auto">
                    <span class="badge" style="background:#f8742c;">Gérer →</span>
                </div>
            </div>
        </a>
    </div>

    {# Retour site #}
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_home') }}" class="card h-100 text-decoration-none shadow-sm border-0" style="transition: transform .15s; background: #1e293b; color: #f1f5f9;">
            <div class="card-body d-flex flex-column gap-3 p-4">
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-2">🌐</span>
                    <div>
                        <div class="fw-bold fs-5">Site public</div>
                        <div class="text-muted small">Retour à la page d'accueil</div>
                    </div>
                </div>
                <div class="mt-auto">
                    <span class="badge bg-secondary">Voir →</span>
                </div>
            </div>
        </a>
    </div>

</div>
{% endblock %}
