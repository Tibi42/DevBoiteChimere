					<li><strong>Date de déclaration :</strong> 14 Septembre 2020</li>
					<li><strong>Numéro RNA (Répertoire National des Associations) :</strong> W751254321</li>
					<li><strong>Siège social :</strong> Maison des Associations du 18e, 15 Passage Ramey, 75018 Paris</li>
					<li><strong>Adresse électronique de contact :</strong> contact@laboiteachimere.fr</li>
				</ul>
			</div>
		</section>

		<!-- Section 2 : Direction de la publication -->
		<section class="rounded-2xl border border-custom glass-card p-6 lg:p-8 shadow-xl">
			<h2 class="text-xl font-bold text-text-primary mb-4 flex items-center gap-3">
