<div class="header-container mx-auto max-w-[1240px] lg:max-w-[1360px] {{ app.user ? 'pl-7 pr-10 lg:pl-12 lg:pr-16' : 'px-7 lg:px-12' }} py-3 bg-custom-secondary rounded-xl shadow-2xl border border-custom flex items-center justify-between">
	<a href="{{ path('app_home') }}" data-turbo="false" class="flex items-center gap-4 transition-all hover:opacity-80 z-[75]">
		<div class="h-10 w-10 shrink-0">
			<svg class="h-full w-full" viewbox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<path d="M20 2L36 12v16L20 38L4 28V12L20 2z" stroke="url(#logo)" stroke-width="1.5" fill="none"/>
				<path d="M20 8l10 6v8l-10 6-10-6v-8l10-6z" stroke="url(#logo2)" stroke-width="1" fill="none"/>
				<defs>
					<linearGradient id="logo" x1="4" y1="2" x2="36" y2="38" gradientunits="userSpaceOnUse">
						<stop stop-color="#14b8a6"/><stop offset="1" stop-color="#f8742c"/>
					</linearGradient>
					<linearGradient id="logo2" x1="10" y1="8" x2="30" y2="32" gradientunits="userSpaceOnUse">
						<stop stop-color="#14b8a6"/><stop offset="1" stop-color="#f8742c"/>
					</linearGradient>
				</defs>
			</svg>
		</div>
		<div class="flex flex-col leading-[0.9]">
			<span class="text-base font-extrabold uppercase tracking-tight text-text-primary leading-none">LA BOÎTE</span>
			<span class="text-base font-extrabold uppercase tracking-tight text-text-primary leading-none">À CHIMÈRE</span>
		</div>
	</a>
	{% if app.user %}
		<span class="hidden lg:block text-[11px] font-bold uppercase tracking-[0.1em] text-text-secondary">Bienvenue <span class="text-custom-orange">{{ app.user.username }}</span></span>
	{% endif %}

	<nav class="hidden lg:flex items-center gap-10">
		<a href="{{ path('app_home') }}" data-turbo="false" class="text-[13px] font-bold uppercase tracking-[0.1em] {{ app.request.attributes.get('_route') == 'app_home' ? 'text-custom-orange' : 'text-text-primary hover:text-custom-orange' }} transition-colors">ACCUEIL</a>
		<a href="{{ path('app_jds') }}" data-turbo="false" class="text-[13px] font-bold uppercase tracking-[0.1em] {{ app.request.attributes.get('_route') == 'app_jds' ? 'text-custom-orange' : 'text-text-primary hover:text-custom-orange' }} transition-colors">JDS</a>
		<a href="{{ path('app_jdr') }}" data-turbo="false" class="text-[13px] font-bold uppercase tracking-[0.1em] {{ app.request.attributes.get('_route') == 'app_jdr' ? 'text-custom-orange' : 'text-text-primary hover:text-custom-orange' }} transition-colors">JDR</a>
		<a href="{{ path('app_gn') }}" data-turbo="false" class="text-[13px] font-bold uppercase tracking-[0.1em] {{ app.request.attributes.get('_route') == 'app_gn' ? 'text-custom-orange' : 'text-text-primary hover:text-custom-orange' }} transition-colors">GN</a>
		<a href="{{ path('app_association') }}" data-turbo="false" class="text-[13px] font-bold uppercase tracking-[0.1em] {{ app.request.attributes.get('_route') == 'app_association' ? 'text-custom-orange' : 'text-text-primary hover:text-custom-orange' }} transition-colors">ASSOCIATION</a>
		<a href="https://laboiteachimere.com/forum/" target="_blank" rel="noopener noreferrer" data-turbo="false" class="text-[13px] font-bold uppercase tracking-[0.1em] text-text-primary hover:text-custom-orange transition-colors">FORUM</a>
		{% if app.user %}
			<a href="{{ path('app_user_dashboard') }}" data-turbo="false" class="text-[13px] font-bold uppercase tracking-[0.1em] {{ app.request.attributes.get('_route') == 'app_user_dashboard' ? 'text-custom-orange' : 'text-text-primary hover:text-custom-orange' }} transition-colors">MON ESPACE</a>
		{% endif %}
		{% if is_granted('ROLE_ADMIN') %}
			<a href="{{ path('admin') }}" class="text-[11px] font-bold uppercase tracking-[0.1em] text-custom-orange hover:text-orange-400 transition-colors">DASHBOARD</a>
		{% endif %}
	</nav>

	<div class="flex items-center gap-4">
		<button type="button" onclick="window.__toggleTheme()" class="theme-toggle-btn p-2.5 rounded-lg bg-custom-tertiary border border-custom text-text-secondary hover:text-text-primary transition-all z-[75]" aria-label="Changer de thème">
			<svg class="h-5 w-5 sun-icon" fill="none" stroke="currentColor" viewbox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
			</svg>
			<svg class="h-5 w-5 moon-icon hidden" fill="none" stroke="currentColor" viewbox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
			</svg>
		</button>
		{% if app.user %}
			<form method="post" action="{{ path('app_logout') }}" class="hidden lg:block" data-turbo="false">
				<input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
				<button type="submit" class="rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-gray-900 cursor-pointer transition-all hover:bg-orange-600 hover:scale-105 hover:shadow-xl hover:shadow-custom-orange/40 shadow-lg shadow-custom-orange/20">
					DÉCONNEXION
				</button>
			</form>
		{% else %}
			<button type="button" id="join-btn" class="hidden lg:block rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-gray-900 cursor-pointer transition-all hover:bg-orange-600 hover:scale-105 hover:shadow-xl hover:shadow-custom-orange/40 shadow-lg shadow-custom-orange/20">
				NOUS REJOINDRE
			</button>
		{% endif %}
		{# Hamburger Menu Button #}
		<button id="mobile-menu-btn" type="button" class="lg:hidden flex flex-col gap-1.5 p-2 z-[100] text-text-primary" aria-label="Menu principal">
			<span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
			<span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
			<span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
		</button>
	</div>
</div>

{# ── Panel connexion desktop : glisse sous la barre ── #}
{% if not app.user %}
	<div id="join-panel" class="hidden sm:block mx-auto max-w-[1240px] lg:max-w-[1360px] overflow-hidden" style="max-height:0;transition:max-height 0.3s ease">
		<div class="bg-custom-secondary border border-t-0 border-custom rounded-b-xl px-7 pt-4 pb-5">
			{% if login_error is defined and login_error %}<p class="mb-3 text-xs font-semibold text-red-400 text-center">{{ login_error.messageKey|trans(login_error.messageData, 'security') }}</p>{% endif %}
			<form action="{{ path('app_login') }}" method="post" data-turbo="false" class="flex flex-col gap-2">
				<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
				<div class="flex items-end gap-3">
					<div class="flex-1">
						<label for="join-username" class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Email</label>
						<input type="email" id="join-username" name="_username" value="{{ last_username|default('') }}" required autocomplete="email" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange {{ (login_error is defined and login_error) ? 'border-red-500' : '' }}" placeholder="votre@email.com">
					</div>
					<div class="flex-1">
						<label for="join-password" class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Mot de passe</label>
						<div class="relative">
							<input type="password" id="join-password" name="_password" required autocomplete="current-password" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 pr-10 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange" placeholder="········">
							<button type="button" data-toggle-password="join-password" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-custom-orange hover:scale-110 transition-all cursor-pointer" tabindex="-1" aria-label="Afficher le mot de passe">
								<svg class="h-4 w-4 eye-closed" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.5 6.5m3.378 3.378L6.5 6.5m0 0L3 3m3.5 3.5l10 10M17.5 17.5L21 21m-3.5-3.5l-10-10m13.043 4.51A9.953 9.953 0 0121 12c-1.275 4.057-5.065 7-9.543 7"/></svg>
								<svg class="h-4 w-4 eye-open hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
							</button>
						</div>
					</div>
					<button type="submit" class="shrink-0 rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-gray-900 cursor-pointer hover:bg-orange-600 hover:scale-105 hover:shadow-xl hover:shadow-custom-orange/40 transition-all shadow-lg shadow-custom-orange/20 min-w-[130px] text-center">SE CONNECTER</button>
					<button type="button" data-open-register class="shrink-0 rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-gray-900 cursor-pointer hover:bg-orange-600 hover:scale-105 hover:shadow-xl hover:shadow-custom-orange/40 transition-all shadow-lg shadow-custom-orange/20 min-w-[130px] text-center">S'INSCRIRE</button>
				</div>
				<a href="{{ path('app_forgot_password_request') }}" class="text-xs text-text-secondary hover:text-custom-orange transition-colors text-center">Mot de passe oublié ?</a>
			</form>
		</div>
	</div>
{% endif %}
