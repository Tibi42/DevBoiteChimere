									<span class="text-xs font-medium text-white/70">Fantasy</span>
									<div class="relative">
										<input type="checkbox" class="sr-only toggle-input" checked>
										<span class="toggle-track toggle-violet">
											<span class="toggle-knob"></span>
										</span>
									</div>
								</label>
								<label class="flex cursor-pointer items-center justify-between p-3 rounded-lg bg-custom-tertiary border border-white/5 hover:border-white/10 transition-all">
									<span class="text-xs font-medium text-white/70">Science-Fiction</span>
									<div class="relative">
										<input type="checkbox" class="sr-only toggle-input" checked>
										<span class="toggle-track toggle-cyan">
											<span class="toggle-knob"></span>
										</span>
									</div>
								</label>
								<label class="flex cursor-pointer items-center justify-between p-3 rounded-lg bg-custom-tertiary border border-white/5 hover:border-white/10 transition-all">
									<span class="text-xs font-medium text-white/70">Horreur</span>
									<div class="relative">
										<input type="checkbox" class="sr-only toggle-input" checked>
										<span class="toggle-track toggle-cyan">
											<span class="toggle-knob"></span>
										</span>
									</div>
								</label>
							</div>
						</section>

						<!-- VOIR LES ARCHIVES (Mobile only here) -->
