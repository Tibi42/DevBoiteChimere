										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
									</svg>
								</a>
								<a href="#" class="flex items-center justify-between p-3 rounded-lg bg-custom-tertiary border border-custom hover:border-custom-orange transition-all group">
									<span class="text-xs font-medium text-text-primary/70 group-hover:text-text-primary">Année 2024</span>
									<svg class="h-3 w-3 text-text-primary/30 group-hover:text-custom-orange transition-colors" fill="none" stroke="currentColor" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
									</svg>
								</a>
								<a href="#" class="flex items-center justify-between p-3 rounded-lg bg-custom-tertiary border border-custom hover:border-custom-orange transition-all group">
									<span class="text-xs font-medium text-text-primary/70 group-hover:text-text-primary">Archives antérieures</span>
									<svg class="h-3 w-3 text-text-primary/30 group-hover:text-custom-orange transition-colors" fill="none" stroke="currentColor" viewbox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
									</svg>
								</a>
							</div>
						</section>
					</div>
				</section>
			</div>
