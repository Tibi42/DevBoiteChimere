							<h3 id="archives-title-mobile" class="text-xs font-bold uppercase tracking-[0.2em] text-white/60 mb-4">VOIR LES ARCHIVES</h3>
							<div class="space-y-2">
								<a href="#" class="flex items-center justify-between p-3 rounded-lg bg-custom-tertiary border border-white/5 hover:border-custom-orange transition-all group">
