				<img src="{{ asset('images/cards/gn.jpg') }}" alt="Grandeur Nature" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-110">
				<div class="absolute inset-0 image-overlay"></div>
				<div class="absolute left-4 top-4 glass h-8 w-8 flex items-center justify-center rounded-lg text-cyan-400">
					<svg class="h-4 w-4" fill="currentColor" viewbox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
				</div>
				<div class="absolute bottom-4 left-4 right-4">
					<h3 class="text-sm font-bold text-white group-hover:text-custom-orange transition-colors">GN (Grandeur Nature)</h3>
				</div>
			</a>
		</div>
	</section>

	<div
		id="separateur" class="relative z-10 mx-auto max-w-[1240px] px-8 lg:px-10 py-12 lg:py-8 lg:-mt-10">
		<!-- Contenu principal -->
		<main class="relative z-10 mx-auto max-w-[1240px] px-8 lg:px-10 pt-0">
			<div
				class="grid gap-12 lg:gap-16 lg:grid-cols-12 items-start">

				<!-- Section ÉVÉNEMENTS À VENIR (Sidebar - Desktop) -->
				<aside class="lg:col-span-4 order-4 lg:order-1 space-y-10">
					<div class="hidden lg:block">
						<h2 class="text-base font-bold uppercase tracking-[0.2em] text-white mb-6 lg:mb-8">ÉVÉNEMENTS À VENIR</h2>
