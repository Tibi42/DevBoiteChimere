{% extends 'base.html.twig' %}

{% block title %}La Boîte à Chimère - Communauté de Jeux de Rôle et de Société
{% endblock %}

{% block importmap %}{{ importmap(['app', 'carousel.js']) }}{% endblock %}

{% block body %}
	<!-- Hero Section avec Carousel, Header et NOS MONDES -->
	<section id="home" class="relative w-full min-h-[600px] lg:min-h-[700px] overflow-hidden mb-12 lg:mb-0">
		<img src="{{ asset('images/hero/hero.jpg') }}" alt="Hero" class="absolute inset-0 h-full w-full object-cover">
		<div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/80"></div>

		<!-- Données du Carousel (fournies par le contrôleur : BDD ou défaut) -->

		<!-- Données Mondes -->
		{% set worlds = [
            { id: 'jdr', name: 'Nos soirées hebdomadaires du mardi (19h)', image: 'jdr.jpg', icon: 'M12 2L2 7v10l10 5 10-5V7L12 2zm0 2.18l6.9 3.45-2.6 5.2-4.3-2.15V4.18zM5.1 7.63L12 4.18v8.55l-4.3 2.15-2.6-5.2zm0 8.74l2.6-5.2 4.3 2.15v4.32L5.1 16.37zm12.8 0l-6.9 3.45v-4.32l4.3-2.15 2.6 5.2z' },
            { id: 'jds', name: 'Nos soirées bi-hebdomadaires du vendredi (19h)', image: 'jds.jpg', icon: 'M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a2 2 0 0 1 2 2v1h1a2 2 0 0 1 2 2v1h1a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2h-1v1a2 2 0 0 1-2 2h-1v1a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-1H7a2 2 0 0 1-2-2v-1H4a2 2 0 0 1-2-2v-1a2 2 0 0 1 2-2h1v-1a2 2 0 0 1 2-2h1v-1a2 2 0 0 1 2-2h1V9a2 2 0 0 1 2-2h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z' },
            { id: 'gn', name: 'Nos apres-midi mensuelles du dimanche (14h)', image: 'gn.jpg', icon: 'M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z' }
        ] %}

		<!-- Contenu par-dessus l'image hero -->
		<div
			class="relative z-10">
			<!-- Carousel Prochain(s) événement(s) -->
			<section class="mx-auto max-w-[1240px] px-4 sm:px-8 lg:px-10 pt-6 lg:pt-10 mb-8 lg:mb-12" id="carousel-container" aria-label="Événements à la une">
				<div class="relative rounded-2xl border border-custom glass-card shadow-xl overflow-hidden">
					<div class="overflow-hidden rounded-2xl">
						<div id="carousel" class="flex h-auto" style="transform: translateX(0%); touch-action: pan-y;">
							{% for slide in slides %}
								{% set btnUrl = slide.btn_url|default('') %}
								{% if btnUrl %}
									<a href="{{ btnUrl }}" class="carousel-events-slide relative group cursor-pointer flex flex-shrink-0 flex-col sm:flex-row sm:items-center justify-between gap-4 p-5 lg:px-6 lg:py-4 min-w-full hover:bg-white/5 transition-colors">
										<div class="flex-1">
											<span class="text-[9px] sm:text-[10px] font-bold uppercase tracking-[0.2em] {{ slide.tag_color }}">{{ slide.tag }}</span>
											<h3 class="text-base sm:text-lg font-bold text-text-primary mt-0.5 leading-tight">{{ slide.title }}</h3>
											<p class="text-xs sm:text-sm text-text-secondary mt-1">{{ slide.date }}</p>
										</div>
										<span class="w-full sm:w-auto text-center shrink-0 rounded-lg {{ slide.btn_class }} px-5 py-2.5 text-[10px] sm:text-xs font-bold uppercase tracking-wider text-text-primary transition-all group-hover:scale-105 shadow-lg">
											{{ slide.btn_text }}
											<span class="absolute inset-0"></span>
										</span>
									</a>
								{% else %}
									<div class="carousel-events-slide relative group cursor-pointer flex flex-shrink-0 flex-col sm:flex-row sm:items-center justify-between gap-4 p-5 lg:px-6 lg:py-4 min-w-full hover:bg-white/5 transition-colors">
										<div class="flex-1">
											<span class="text-[9px] sm:text-[10px] font-bold uppercase tracking-[0.2em] {{ slide.tag_color }}">{{ slide.tag }}</span>
											<h3 class="text-base sm:text-lg font-bold text-text-primary mt-0.5 leading-tight">{{ slide.title }}</h3>
											<p class="text-xs sm:text-sm text-text-secondary mt-1">{{ slide.date }}</p>
										</div>
										<span class="w-full sm:w-auto text-center shrink-0 rounded-lg {{ slide.btn_class }} px-5 py-2.5 text-[10px] sm:text-xs font-bold uppercase tracking-wider text-text-primary transition-all group-hover:scale-105 shadow-lg">
											{{ slide.btn_text }}
											<span class="absolute inset-0"></span>
										</span>
									</div>
								{% endif %}
							{% endfor %}
						</div>
					</div>
				</div>
				<div id="carousel-events-dots" class="flex justify-center items-center gap-3 py-4 mt-2">
					{% for slide in slides %}
						<button type="button" class="carousel-events-dot h-3 w-3 rounded-full transition-all bg-white/50 hover:bg-white/80" data-index="{{ loop.index0 }}" data-slide="{{ loop.index0 }}"></button>
					{% endfor %}
				</div>
			</section>

			<!-- Header -->
			<header class="mx-auto max-w-[1240px] lg:max-w-[1360px] px-8 lg:px-10 mb-12 lg:mb-16">
				<div class="header-container mx-auto max-w-[1240px] lg:max-w-[1360px] px-7 py-3 bg-custom-secondary rounded-xl shadow-2xl border border-custom flex items-center justify-between">
					<a href="/#home" data-turbo="false" class="flex items-center gap-4 transition-all hover:opacity-80 z-[75]">
						<div class="h-10 w-10 shrink-0">
							<svg class="h-full w-full" viewbox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
								<path d="M20 2L36 12v16L20 38L4 28V12L20 2z" stroke="url(#logo)" stroke-width="1.5" fill="none"/>
								<path d="M20 8l10 6v8l-10 6-10-6v-8l10-6z" stroke="url(#logo2)" stroke-width="1" fill="none"/>
								<defs>
									<linearGradient id="logo" x1="4" y1="2" x2="36" y2="38" gradientunits="userSpaceOnUse">
										<stop stop-color="#14b8a6"/><stop offset="1" stop-color="#f8742c"/>
									</linearGradient>
									<linearGradient id="logo2" x1="10" y1="8" x2="30" y2="32" gradientunits="userSpaceOnUse">
										<stop stop-color="#14b8a6"/><stop offset="1" stop-color="#f8742c"/>
									</linearGradient>
								</defs>
							</svg>
						</div>
						<div class="flex flex-col leading-[0.9]">
							<span class="text-base font-extrabold uppercase tracking-tight text-text-primary leading-none">LA BOÎTE</span>
							<span class="text-base font-extrabold uppercase tracking-tight text-text-primary leading-none">À CHIMÈRE</span>
						</div>
					</a>

					<nav class="hidden lg:flex items-center gap-10">
						<a href="#jds" data-turbo="false" class="text-[11px] font-bold uppercase tracking-[0.1em] text-text-secondary hover:text-text-primary transition-colors">JDS</a>
						<a href="#jdr" data-turbo="false" class="text-[11px] font-bold uppercase tracking-[0.1em] text-text-secondary hover:text-text-primary transition-colors">JDR</a>
						<a href="#gn" data-turbo="false" class="text-[11px] font-bold uppercase tracking-[0.1em] text-text-secondary hover:text-text-primary transition-colors">GN</a>
						<a href="#association" data-turbo="false" class="text-[11px] font-bold uppercase tracking-[0.1em] text-text-secondary hover:text-text-primary transition-colors">ASSOCIATION</a>
						<a href="#forum" data-turbo="false" class="text-[11px] font-bold uppercase tracking-[0.1em] text-text-secondary hover:text-text-primary transition-colors">FORUM</a>
					{% if is_granted('ROLE_ADMIN') %}
						<a href="{{ path('admin') }}" class="text-[11px] font-bold uppercase tracking-[0.1em] text-custom-orange hover:text-orange-400 transition-colors">DASHBOARD</a>
					{% endif %}
					</nav>

					<div class="flex items-center gap-4">
						<button id="theme-toggle" type="button" class="p-2.5 rounded-lg bg-custom-tertiary border border-custom text-text-secondary hover:text-text-primary transition-all z-[75]" aria-label="Changer de thème">
							<svg class="h-5 w-5 sun-icon" fill="none" stroke="currentColor" viewbox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
							</svg>
							<svg class="h-5 w-5 moon-icon hidden" fill="none" stroke="currentColor" viewbox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
							</svg>
						</button>
						{% if app.user %}
							<a href="{{ path('app_logout') }}" class="hidden lg:block rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-text-primary transition-all hover:bg-orange-600 hover:scale-105 shadow-lg shadow-custom-orange/20">
								DÉCONNEXION
							</a>
						{% else %}
							<button type="button" id="join-btn" class="hidden lg:block rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-text-primary transition-all hover:bg-orange-600 hover:scale-105 shadow-lg shadow-custom-orange/20">
								NOUS REJOINDRE
							</button>
						{% endif %}
						<!-- Hamburger Menu Button -->
						<button id="mobile-menu-btn" type="button" class="lg:hidden flex flex-col gap-1.5 p-2 z-[100] text-text-primary" aria-label="Menu principal">
							<span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
							<span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
							<span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center"></span>
						</button>
					</div>
				</div>

				<!-- Panel connexion : glisse sous la barre -->
				<div id="join-panel" class="hidden sm:block mx-auto max-w-[1240px] lg:max-w-[1360px] overflow-hidden" style="max-height:0;transition:max-height 0.3s ease">
					<div class="bg-custom-secondary border border-t-0 border-custom rounded-b-xl px-7 pt-4 pb-5">
						{% if login_error %}<p class="mb-3 text-xs font-semibold text-red-400 text-center">{{ login_error.messageKey|trans(login_error.messageData, 'security') }}</p>{% endif %}
						<form action="{{ path('app_login') }}" method="post" data-turbo="false" class="flex flex-col gap-2">
							<input type="hidden" name="_csrf_token" value="{{ login_csrf_token }}">
							<div class="flex items-end gap-3">
								<div class="flex-1">
									<label for="join-username" class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Email</label>
									<input type="email" id="join-username" name="_username" value="{{ last_username }}" required autocomplete="email" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange {{ login_error ? 'border-red-500' : '' }}" placeholder="votre@email.com">
								</div>
								<div class="flex-1">
									<label for="join-password" class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary mb-1.5">Mot de passe</label>
									<input type="password" id="join-password" name="_password" required autocomplete="current-password" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange" placeholder="········">
								</div>
								<button type="submit" class="shrink-0 rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-text-primary hover:bg-orange-600 hover:scale-105 transition-all shadow-lg shadow-custom-orange/20 min-w-[155px] text-center">SE CONNECTER</button>
							</div>
							<a href="{{ path('app_forgot_password_request') }}" class="text-xs text-text-secondary hover:text-custom-orange transition-colors text-center">Mot de passe oublié ?</a>
						</form>
					</div>
				</div>
			</header>
			<!-- Mobile Menu Drawer -->
			<div id="mobile-menu-drawer" class="fixed inset-0 z-[95] lg:hidden pointer-events-none">
				<div id="mobile-menu-overlay" class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
				<div id="mobile-menu-content" class="absolute top-0 right-0 bottom-0 w-[280px] bg-custom-secondary border-l border-custom shadow-2xl pt-20 px-8">
					<nav class="flex flex-col gap-6">
						<a href="#jds" data-turbo="false" class="mobile-nav-link text-lg font-bold uppercase tracking-widest text-text-primary/70 hover:text-custom-orange transition-colors">JDS</a>
						<a href="#jdr" data-turbo="false" class="mobile-nav-link text-lg font-bold uppercase tracking-widest text-text-primary/70 hover:text-custom-orange transition-colors">JDR</a>
						<a href="#gn" data-turbo="false" class="mobile-nav-link text-lg font-bold uppercase tracking-widest text-text-primary/70 hover:text-custom-orange transition-colors">GN</a>
						<a href="#association" data-turbo="false" class="mobile-nav-link text-lg font-bold uppercase tracking-widest text-text-primary/70 hover:text-custom-orange transition-colors">ASSOCIATION</a>
						<a href="#forum" data-turbo="false" class="mobile-nav-link text-lg font-bold uppercase tracking-widest text-text-secondary hover:text-custom-orange transition-colors">FORUM</a>
						{% if is_granted('ROLE_ADMIN') %}
							<a href="{{ path('admin') }}" class="text-lg font-bold uppercase tracking-widest text-custom-orange hover:text-orange-400 transition-colors">DASHBOARD</a>
						{% endif %}
						<hr class="border-custom my-4">
						{% if app.user %}
							<a href="{{ path('app_logout') }}" class="mt-2 w-full rounded-lg bg-custom-orange px-6 py-4 text-center text-sm font-extrabold uppercase tracking-widest text-text-primary shadow-lg shadow-custom-orange/20 hover:bg-orange-600 transition-all block">
								DÉCONNEXION
							</a>
						{% else %}
							<button id="mobile-join-btn" type="button" class="mt-2 w-full rounded-lg bg-custom-orange px-6 py-4 text-center text-sm font-extrabold uppercase tracking-widest text-text-primary shadow-lg shadow-custom-orange/20 hover:bg-orange-600 transition-all">
								NOUS REJOINDRE
							</button>
						{% endif %}
						<div id="mobile-join-form" class="overflow-hidden" style="max-height:0;transition:max-height 0.3s ease">
							{% if login_error %}<p class="mb-2 text-xs font-semibold text-red-400 text-center">{{ login_error.messageKey|trans(login_error.messageData, 'security') }}</p>{% endif %}
							<form action="{{ path('app_login') }}" method="post" data-turbo="false" class="flex flex-col gap-3 pt-4">
								<input type="hidden" name="_csrf_token" value="{{ login_csrf_token }}">
								<div>
									<label for="mobile-join-username" class="block text-xs font-bold uppercase tracking-wider text-text-secondary mb-1">Email</label>
									<input type="email" id="mobile-join-username" name="_username" value="{{ last_username }}" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange {{ login_error ? 'border-red-500' : '' }}" placeholder="votre@email.com" autocomplete="email">
								</div>
								<div>
									<label for="mobile-join-password" class="block text-xs font-bold uppercase tracking-wider text-text-secondary mb-1">Mot de passe</label>
									<input type="password" id="mobile-join-password" name="_password" class="w-full rounded-lg border border-custom bg-custom-tertiary px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/60 focus:border-custom-orange focus:outline-none focus:ring-1 focus:ring-custom-orange" placeholder="········" autocomplete="current-password">
								</div>
								<button type="submit" class="w-full rounded-lg bg-custom-orange px-6 py-3 text-[11px] font-extrabold uppercase tracking-[0.05em] text-text-primary hover:bg-orange-600 transition-all shadow-lg shadow-custom-orange/20">SE CONNECTER</button>
								<a href="{{ path('app_forgot_password_request') }}" class="block text-center text-xs text-text-secondary hover:text-custom-orange transition-colors mt-1">Mot de passe oublié ?</a>
							</form>
						</div>
					</nav>
					<div class="absolute bottom-10 left-8 right-8 text-center">
						<p class="text-[10px] uppercase tracking-widest text-text-secondary/30 font-bold">&copy; LA BOÎTE À CHIMÈRE</p>
					</div>
				</div>
			</div>

				{# Modal d'ajout d'événement.
			   Mobile : carte inline au-dessus du calendrier.
			   Desktop : le JS la déplace dans <body> pour éviter le stacking context. #}
			<div id="activity-modal"
				 class="hidden px-8 mb-6">
				<div class="glass-card rounded-2xl border border-custom shadow-2xl w-full lg:max-w-lg relative p-6">
					<turbo-frame id="activity-modal-frame" loading="lazy"></turbo-frame>
				</div>
			</div>

			<!-- ÉVÉNEMENTS À VENIR (Mobile only - inside hero for layout flow). Turbo-frame : mise à jour partielle pour ne pas fermer le menu / modales. -->
			<turbo-frame id="calendar-frame">
				<div id="calendar" class="lg:hidden mx-auto max-w-[1240px] px-8 mb-8">
					<h2 class="text-base font-bold uppercase tracking-[0.2em] text-text-primary mb-6">ÉVÉNEMENTS À VENIR</h2>
					<article class="bg-custom-primary p-5 rounded-xl border border-custom relative shadow-2xl glass-card">
						{# Navigation mois #}
						<div class="flex items-center justify-between mb-4">
							<a href="{{ path('app_home', { month: prevMonth, year: prevYear }) }}#calendar" class="text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors">&larr; {{ prevMonthName }}</a>
							<span class="text-[10px] font-bold uppercase tracking-wider text-text-primary">{{ calendarMonthName }} {{ calendarYear }}</span>
							<a href="{{ path('app_home', { month: nextMonth, year: nextYear }) }}#calendar" class="text-[10px] font-bold uppercase tracking-wider text-text-secondary hover:text-custom-orange transition-colors">{{ nextMonthName }} &rarr;</a>
						</div>
						<div class="flex gap-4 mb-6">
							<div class="flex-1">
								<div class="grid grid-cols-7 gap-1 text-center text-[10px] font-bold uppercase tracking-tighter text-text-secondary mb-4">
									<span>Lu</span>
									<span>Ma</span>
									<span>Me</span>
									<span>Je</span>
									<span>Ve</span>
									<span>Sa</span>
									<span class="text-cyan-400">Di</span>
									{% for day in calendarDays %}
										{% if day is not null %}
											{% set isFuture = (calendarYear > nowYear)
												or (calendarYear == nowYear and calendarMonth > nowMonth)
												or (calendarYear == nowYear and calendarMonth == nowMonth and day > nowDay) %}
											{% set isToday = (calendarYear == nowYear and calendarMonth == nowMonth and day == nowDay) %}
											{% set isClickable = is_granted('ROLE_USER') and (isToday or isFuture) %}
											{% if day in daysWithActivities %}
												<a href="{{ path('app_home', { month: calendarMonth, year: calendarYear, day: day }) }}#calendar" class="block py-2 rounded bg-custom-orange text-text-primary shadow-lg shadow-custom-orange/40 hover:ring-2 hover:ring-white transition-all {{ selectedDay == day ? 'ring-2 ring-white' : '' }}" title="{{ activitiesCountByDay[day] ?? 1 }} événement(s)">
													<span>{{ day }}</span>
													{% if (activitiesCountByDay[day] ?? 1) > 1 %}
														<span class="block text-[8px] opacity-90">{{ activitiesCountByDay[day] }}</span>
													{% endif %}
												</a>
											{% elseif isToday %}
												{% if isClickable %}
													<button type="button" data-modal-url="{{ path('app_activity_new_public', {date: calendarYear ~ '-' ~ '%02d'|format(calendarMonth) ~ '-' ~ '%02d'|format(day)}) }}" class="block w-full py-2 hover:text-custom-orange hover:bg-custom-orange/10 rounded transition-colors cursor-pointer text-custom-orange font-bold underline underline-offset-2" title="Ajouter un événement">{{ day }}</button>
												{% else %}
													<span class="py-2 text-custom-orange font-bold underline underline-offset-2">{{ day }}</span>
												{% endif %}
											{% elseif isClickable %}
												<button type="button" data-modal-url="{{ path('app_activity_new_public', {date: calendarYear ~ '-' ~ '%02d'|format(calendarMonth) ~ '-' ~ '%02d'|format(day)}) }}" class="block w-full py-2 hover:text-custom-orange hover:bg-custom-orange/10 rounded transition-colors cursor-pointer" title="Ajouter un événement">{{ day }}</button>
											{% else %}
												<span class="py-2">{{ day }}</span>
											{% endif %}
										{% else %}
											<span class="py-2"></span>
										{% endif %}
									{% endfor %}
								</div>
							</div>
						</div>
						{% if selectedDay %}
							<p class="text-[10px] font-bold uppercase tracking-wider text-custom-orange mb-3">
								Événements du {{ selectedDay }} {{ calendarMonthName }}
								{% if activitiesForSelectedDay|length > 1 %}
									<span class="text-text-secondary font-normal">({{ activitiesForSelectedDay|length }} événements)</span>
								{% endif %}
							</p>
							{% for activity in activitiesForSelectedDay %}
							<div class="rounded-xl bg-custom-secondary/40 p-4 border border-custom mb-4 last:mb-0">
								<div class="flex justify-between items-start mb-1">
									{% set actType = activity.type|default('Play Test') %}
													{% if actType == 'JDS' %}
														<span class="text-[9px] font-bold uppercase tracking-widest text-emerald-400 px-2 py-0.5 rounded bg-emerald-400/10">{{ actType }}</span>
													{% elseif actType == 'JDR' %}
														<span class="text-[9px] font-bold uppercase tracking-widest text-violet-400 px-2 py-0.5 rounded bg-violet-400/10">{{ actType }}</span>
													{% elseif actType == 'GN' %}
														<span class="text-[9px] font-bold uppercase tracking-widest text-red-400 px-2 py-0.5 rounded bg-red-400/10">{{ actType }}</span>
													{% elseif actType == 'JDF' %}
														<span class="text-[9px] font-bold uppercase tracking-widest text-sky-400 px-2 py-0.5 rounded bg-sky-400/10">{{ actType }}</span>
													{% elseif actType == 'AG' %}
														<span class="text-[9px] font-bold uppercase tracking-widest text-amber-400 px-2 py-0.5 rounded bg-amber-400/10">{{ actType }}</span>
													{% else %}
